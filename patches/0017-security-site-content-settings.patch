+// --- Site settings (S7) ----------------------------------------------------
+
+// The active tab's origin key, or empty for internal pages (no http/https).
+- (std::string)activeOriginKey {
+  content::Shell* shell = [self activeShell];
+  if (!shell)
+    return std::string();
+  GURL url = shell->web_contents()->GetLastCommittedURL();
+  if (!url.SchemeIs("http") && !url.SchemeIsCryptographic())
+    return std::string();
+  return url::Origin::Create(url).Serialize();
+}
+
+- (BOOL)activeTabHasWebOrigin {
+  return ![self activeOriginKey].empty();
+}
+
+- (BOOL)javaScriptEnabledForActiveTab {
+  std::string origin = [self activeOriginKey];
+  if (origin.empty())
+    return YES;
+  std::optional<bool> js =
+      content::ShellContentBrowserClient::Get()->GetSitePermission(origin,
+                                                                   "javascript");
+  return js.value_or(true);
+}
+
+- (void)toggleSiteJavaScript:(id)sender {
+  content::Shell* shell = [self activeShell];
+  std::string origin = [self activeOriginKey];
+  if (!shell || origin.empty())
+    return;
+  BOOL enabled = ([sender state] == NSControlStateValueOn);
+  content::ShellContentBrowserClient::Get()->SetSitePermission(
+      origin, "javascript", enabled);
+  // Re-apply WebPreferences and reload so the change takes effect on the page.
+  shell->web_contents()->OnWebPreferencesChanged();
+  shell->web_contents()->GetController().Reload(content::ReloadType::NORMAL,
+                                                false);
+  if (_certPopover)
+    [_certPopover close];
+}
+
+- (BOOL)thirdPartyCookiesBlocked {
+  return content::ShellContentBrowserClient::Get()
+      ->GetSitePermission("*", "block_third_party_cookies")
+      .value_or(false);
+}
+
+- (void)toggleThirdPartyCookies:(id)sender {
+  BOOL block = ([sender state] == NSControlStateValueOn);
+  content::ShellContentBrowserClient::Get()->SetSitePermission(
+      "*", "block_third_party_cookies", block);
+  [self applyThirdPartyCookieBlocking:block];
+  if (_certPopover)
+    [_certPopover close];
+}
+
+// Pushes the third-party-cookie setting to the network service's cookie manager.
+- (void)applyThirdPartyCookieBlocking:(BOOL)block {
+  content::Shell* shell = [self activeShell];
+  if (!shell)
+    return;
+  shell->web_contents()
+      ->GetBrowserContext()
+      ->GetDefaultStoragePartition()
+      ->GetCookieManagerForBrowserProcess()
+      ->BlockThirdPartyCookies(block);
+}
