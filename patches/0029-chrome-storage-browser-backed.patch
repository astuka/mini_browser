+void ShellRenderFrameObserver::InstallChromeApi(
+    v8::Local<v8::Context> context,
+    const std::string& extension_id) {
   v8::Isolate* isolate = v8::Isolate::GetCurrent();
   v8::HandleScope handle_scope(isolate);
   v8::Context::Scope context_scope(context);
   v8::TryCatch try_catch(isolate);
+
+  // Build the native bridge object (chrome.storage transport) bound to this
+  // frame's observer; it is passed into the shim function so it never lands on
+  // the page's global.
+  v8::Local<v8::Object> api = v8::Object::New(isolate);
+  auto install_fn = [&](const char* name,
+                        v8::Local<v8::Value> (ShellRenderFrameObserver::*method)(
+                            gin::Arguments*)) {
+    // base::Unretained is safe: these functions live in the frame's v8 context,
+    // which is torn down before the RenderFrame (and thus this observer), so
+    // they are never invoked after `this` is gone. (A WeakPtr can't be used —
+    // base forbids binding one to a method with a non-void return.)
+    v8::Local<v8::Function> fn;
+    if (!gin::CreateFunctionTemplate(
+             isolate, base::BindRepeating(method, base::Unretained(this)))
+             ->GetFunction(context)
+             .ToLocal(&fn)) {
+      return;
+    }
+    if (api->Set(context, gin::StringToSymbol(isolate, name), fn).IsNothing()) {
+      return;
+    }
+  };
+  install_fn("storageGet", &ShellRenderFrameObserver::StorageGet);
+  install_fn("storageSet", &ShellRenderFrameObserver::StorageSet);
+  install_fn("storageRemove", &ShellRenderFrameObserver::StorageRemove);
