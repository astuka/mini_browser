+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+module content.mojom;
+
+// Browser-implemented, bound per RenderFrame. The browser-backed transport for
+// our from-scratch `chrome.*` runtime (Wield epic, W1) — it replaces E5's
+// pure-JS localStorage shim so an extension's data lives in one
+// browser-persisted store shared across all of the extension's contexts
+// (popup, options, background, and — once W1b lands — content scripts).
+//
+// `extension_id` identifies which extension's store to touch. Storage payloads
+// are passed as JSON text so arbitrary extension values cross the boundary
+// without a structured-value dependency; the renderer keeps the chrome.storage
+// key/default semantics and the browser is just a persistent key→value blob
+// store per extension.
+interface ExtensionApi {
+  // Returns the extension's entire storage blob as a JSON object string ("{}"
+  // when empty). The renderer applies get(keys)/defaults locally.
+  StorageGet(string extension_id) => (string json);
+
+  // Merges the keys in `items_json` (a JSON object) into the store.
+  StorageSet(string extension_id, string items_json) => ();
+
+  // Removes each key named in `keys_json` (a JSON array of strings).
+  StorageRemove(string extension_id, string keys_json) => ();
+
+  // Empties the extension's store.
+  StorageClear(string extension_id) => ();
+};
