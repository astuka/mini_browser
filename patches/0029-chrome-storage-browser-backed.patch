@@ -0,0 +1,81 @@
+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/shell/browser/shell_extension_api_impl.h"
+
+#include <optional>
+#include <utility>
+
+#include "base/json/json_reader.h"
+#include "base/json/json_writer.h"
+#include "base/values.h"
+#include "content/shell/browser/shell_content_browser_client.h"
+#include "mojo/public/cpp/bindings/self_owned_receiver.h"
+
+namespace content {
+
+// static
+void ShellExtensionApiImpl::Create(
+    RenderFrameHost* render_frame_host,
+    mojo::PendingReceiver<mojom::ExtensionApi> receiver) {
+  mojo::MakeSelfOwnedReceiver(std::make_unique<ShellExtensionApiImpl>(),
+                              std::move(receiver));
+}
+
+ShellExtensionApiImpl::ShellExtensionApiImpl() = default;
+ShellExtensionApiImpl::~ShellExtensionApiImpl() = default;
+
+void ShellExtensionApiImpl::StorageGet(const std::string& extension_id,
+                                       StorageGetCallback callback) {
+  base::DictValue data =
+      ShellContentBrowserClient::Get()->GetExtensionStorageDict(extension_id);
+  std::string json;
+  base::JSONWriter::Write(data, &json);
+  std::move(callback).Run(json);
+}
+
+void ShellExtensionApiImpl::StorageSet(const std::string& extension_id,
+                                       const std::string& items_json,
+                                       StorageSetCallback callback) {
+  base::DictValue data =
+      ShellContentBrowserClient::Get()->GetExtensionStorageDict(extension_id);
+  std::optional<base::Value> items =
+      base::JSONReader::Read(items_json, base::JSON_PARSE_RFC);
+  if (items && items->is_dict()) {
+    for (auto&& [key, value] : items->GetDict()) {
+      data.Set(key, value.Clone());
+    }
+  }
+  ShellContentBrowserClient::Get()->SetExtensionStorageDict(extension_id,
+                                                            std::move(data));
+  std::move(callback).Run();
+}
+
+void ShellExtensionApiImpl::StorageRemove(const std::string& extension_id,
+                                          const std::string& keys_json,
+                                          StorageRemoveCallback callback) {
+  base::DictValue data =
+      ShellContentBrowserClient::Get()->GetExtensionStorageDict(extension_id);
+  std::optional<base::Value> keys =
+      base::JSONReader::Read(keys_json, base::JSON_PARSE_RFC);
+  if (keys && keys->is_list()) {
+    for (const base::Value& key : keys->GetList()) {
+      if (key.is_string()) {
+        data.Remove(key.GetString());
+      }
+    }
+  }
+  ShellContentBrowserClient::Get()->SetExtensionStorageDict(extension_id,
+                                                            std::move(data));
+  std::move(callback).Run();
+}
+
+void ShellExtensionApiImpl::StorageClear(const std::string& extension_id,
+                                         StorageClearCallback callback) {
+  ShellContentBrowserClient::Get()->SetExtensionStorageDict(extension_id,
+                                                            base::DictValue());
+  std::move(callback).Run();
+}
+
+}  // namespace content
