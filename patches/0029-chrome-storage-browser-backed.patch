+// found in the LICENSE file.
+
+#ifndef CONTENT_SHELL_BROWSER_SHELL_EXTENSION_API_IMPL_H_
+#define CONTENT_SHELL_BROWSER_SHELL_EXTENSION_API_IMPL_H_
+
+#include <string>
+
+#include "content/shell/common/shell_extension_api.mojom.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+
+namespace content {
+
+class RenderFrameHost;
+
+// Browser-side implementation of the `chrome.*` transport (Wield epic, W1a).
+// Bound once per RenderFrame; for now it backs `chrome.storage.local` with a
+// per-extension JSON store persisted in local state, shared across every
+// context of an extension. Built on content_shell, not //chrome/browser/extensions.
+class ShellExtensionApiImpl : public mojom::ExtensionApi {
+ public:
+  // Binder for ShellContentBrowserClient::RegisterBrowserInterfaceBindersForFrame.
+  static void Create(RenderFrameHost* render_frame_host,
+                     mojo::PendingReceiver<mojom::ExtensionApi> receiver);
+
+  ShellExtensionApiImpl();
+  ~ShellExtensionApiImpl() override;
+
+  ShellExtensionApiImpl(const ShellExtensionApiImpl&) = delete;
+  ShellExtensionApiImpl& operator=(const ShellExtensionApiImpl&) = delete;
+
+  // mojom::ExtensionApi:
+  void StorageGet(const std::string& extension_id,
+                  StorageGetCallback callback) override;
+  void StorageSet(const std::string& extension_id,
+                  const std::string& items_json,
+                  StorageSetCallback callback) override;
+  void StorageRemove(const std::string& extension_id,
+                     const std::string& keys_json,
+                     StorageRemoveCallback callback) override;
+  void StorageClear(const std::string& extension_id,
+                    StorageClearCallback callback) override;
+};
+
+}  // namespace content
+
+#endif  // CONTENT_SHELL_BROWSER_SHELL_EXTENSION_API_IMPL_H_
