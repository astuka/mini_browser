+// Selects every tab between the anchor and `node` in the visible flat order
+// (inclusive), skipping folder rows.
+- (void)selectRangeFromAnchorTo:(TabNode*)node {
+  [self rebuildFlatRows];
+  NSUInteger a = [_flatRows indexOfObject:_selectionAnchor];
+  NSUInteger b = [_flatRows indexOfObject:node];
+  if (a == NSNotFound || b == NSNotFound)
+    return;
+  NSUInteger lo = std::min(a, b);
+  NSUInteger hi = std::max(a, b);
+  [_selection removeAllObjects];
+  for (NSUInteger i = lo; i <= hi; ++i) {
+    TabNode* n = _flatRows[i];
+    if (n->kind == TabNodeKindTab)
+      [_selection addObject:n];
+  }
+}
