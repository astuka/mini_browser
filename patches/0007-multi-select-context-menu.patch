-// A plain click on a row: a folder toggles open/closed; a tab is activated.
-- (void)rowClicked:(TabNode*)node {
+// A click on a row. A folder always toggles open/closed. For a tab, the
+// modifiers decide: ⌘ toggles it in the multi-selection, Shift extends a range
+// from the anchor, and a plain click activates it (and resets the selection to
+// just that tab). Only a plain click loads/shows the tab.
+- (void)rowClicked:(TabNode*)node modifiers:(NSEventModifierFlags)modifiers {
   if (!node)
     return;
   if (node->kind == TabNodeKindFolder) {
@@ -901,11 +921,54 @@ - (void)rowClicked:(TabNode*)node {
     [self layoutTabRows];
     return;
   }
+
+  BOOL command = (modifiers & NSEventModifierFlagCommand) != 0;
+  BOOL shift = (modifiers & NSEventModifierFlagShift) != 0;
+
+  if (command) {
+    if ([_selection containsObject:node])
+      [_selection removeObject:node];
+    else
+      [_selection addObject:node];
+    _selectionAnchor = node;
+    [self restyleAllRows];
+    return;
+  }
+
+  if (shift && _selectionAnchor) {
+    [self selectRangeFromAnchorTo:node];
+    [self restyleAllRows];
+    return;
+  }
+
+  // Plain click: selection collapses to this tab, and we activate it.
+  [_selection removeAllObjects];
+  [_selection addObject:node];
+  _selectionAnchor = node;
   [self activateTab:node];
+  [self restyleAllRows];
   if (node->shell)
