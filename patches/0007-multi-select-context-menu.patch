+// --- Context menu ----------------------------------------------------------
+
+- (NSArray<TabNode*>*)allFolders {
+  NSMutableArray<TabNode*>* out = [NSMutableArray array];
+  for (TabNode* node in [self allNodes])
+    if (node->kind == TabNodeKindFolder)
+      [out addObject:node];
+  return out;
+}
+
+- (void)collectTabsIn:(NSArray<TabNode*>*)nodes
+                 into:(NSMutableArray<TabNode*>*)out {
+  for (TabNode* node in nodes) {
+    if (node->kind == TabNodeKindTab)
+      [out addObject:node];
+    if (node->children)
+      [self collectTabsIn:node->children into:out];
+  }
+}
+
+// The selected tabs in visible (flat) order — the order menu actions act in.
+- (NSArray<TabNode*>*)selectionInFlatOrder {
+  [self rebuildFlatRows];
+  NSMutableArray<TabNode*>* out = [NSMutableArray array];
+  for (TabNode* node in _flatRows)
+    if ([_selection containsObject:node])
+      [out addObject:node];
+  return out;
+}
+
+- (NSMenu*)contextMenuForNode:(TabNode*)node {
+  if (!node)
+    return nil;
+
+  // Right-clicking a tab that isn't already selected makes it the selection,
+  // matching how Finder/most lists behave.
+  if (node->kind == TabNodeKindTab && ![_selection containsObject:node]) {
+    [_selection removeAllObjects];
+    [_selection addObject:node];
+    _selectionAnchor = node;
+    [self restyleAllRows];
+  }
+
+  NSMenu* menu = [[NSMenu alloc] init];
+
+  if (node->kind == TabNodeKindFolder) {
+    // Folder menu. PR 9 will add a "Rename Folder…" item here.
+    NSMenuItem* close =
+        [[NSMenuItem alloc] initWithTitle:@"Close Folder"
+                                   action:@selector(closeFolderFromMenu:)
+                            keyEquivalent:@""];
+    close.target = self;
+    close.representedObject = node;
+    [menu addItem:close];
+    return menu;
+  }
+
+  NSUInteger count = _selection.count;
+  NSString* closeTitle = (count > 1)
+                             ? [NSString stringWithFormat:@"Close %lu Tabs",
+                                                          (unsigned long)count]
+                             : @"Close Tab";
+  NSMenuItem* close =
+      [[NSMenuItem alloc] initWithTitle:closeTitle
+                                 action:@selector(closeSelectionFromMenu:)
+                          keyEquivalent:@""];
+  close.target = self;
+  [menu addItem:close];
+
+  [menu addItem:[NSMenuItem separatorItem]];
+
+  NSMenuItem* newFolder = [[NSMenuItem alloc]
+      initWithTitle:@"Move to New Folder"
+             action:@selector(moveSelectionToNewFolderFromMenu:)
+      keyEquivalent:@""];
+  newFolder.target = self;
+  [menu addItem:newFolder];
+
+  NSArray<TabNode*>* folders = [self allFolders];
+  if (folders.count > 0) {
+    NSMenuItem* moveItem = [[NSMenuItem alloc] initWithTitle:@"Move to Folder"
+                                                     action:nil
+                                              keyEquivalent:@""];
+    NSMenu* submenu = [[NSMenu alloc] init];
+    for (TabNode* folder in folders) {
+      NSString* name =
+          folder->folderTitle.length ? folder->folderTitle : @"Folder";
+      NSMenuItem* item = [[NSMenuItem alloc]
+          initWithTitle:name
+                 action:@selector(moveSelectionToFolderFromMenu:)
+          keyEquivalent:@""];
+      item.target = self;
+      item.representedObject = folder;
+      [submenu addItem:item];
+    }
+    moveItem.submenu = submenu;
+    [menu addItem:moveItem];
+  }
+
+  [menu addItem:[NSMenuItem separatorItem]];
+
+  NSString* bmTitle =
+      (count > 1) ? [NSString stringWithFormat:@"Add %lu Tabs to Bookmarks",
+                                               (unsigned long)count]
+                  : @"Add to Bookmarks";
+  NSMenuItem* bookmark =
+      [[NSMenuItem alloc] initWithTitle:bmTitle
+                                 action:@selector(addSelectionToBookmarksFromMenu:)
+                          keyEquivalent:@""];
+  bookmark.target = self;
+  [menu addItem:bookmark];
+
+  return menu;
+}
+
+- (void)closeSelectionFromMenu:(id)sender {
+  NSArray<TabNode*>* snapshot = [_selection copy];
+  [_selection removeAllObjects];
+  for (TabNode* tab in snapshot) {
+    // Close() deletes the Shell -> removeTabForShell: updates the tree/UI.
+    if (tab->shell)
+      tab->shell->Close();
+  }
+}
+
+// Moves all selected tabs into a freshly created folder placed at the topmost
+// selected tab's slot.
+- (void)moveSelectionToNewFolderFromMenu:(id)sender {
+  NSArray<TabNode*>* ordered = [self selectionInFlatOrder];
+  if (ordered.count == 0)
+    return;
+  TabNode* topmost = ordered.firstObject;
+
+  TabNode* folder = [self makeFolderNode];
+  [_sidebar addSubview:folder->rowView];
+  NSMutableArray<TabNode*>* container =
+      topmost->parent ? topmost->parent->children : _tabs;
+  NSUInteger idx = [container indexOfObject:topmost];
+  if (idx == NSNotFound)
+    idx = container.count;
+  folder->parent = topmost->parent;
+  [container insertObject:folder atIndex:idx];
+
+  [self moveTabs:ordered intoFolder:folder];
+}
+
+- (void)moveSelectionToFolderFromMenu:(id)sender {
+  TabNode* folder = [sender representedObject];
+  if (!folder || folder->kind != TabNodeKindFolder)
+    return;
+  [self moveTabs:[self selectionInFlatOrder] intoFolder:folder];
+}
+
+// Shared mover: reparents `tabs` into `folder`, then prunes any folders they
+// left behind.
+- (void)moveTabs:(NSArray<TabNode*>*)tabs intoFolder:(TabNode*)folder {
+  NSMutableSet<TabNode*>* oldParents = [NSMutableSet set];
+  for (TabNode* tab in tabs) {
+    if (tab == folder)
+      continue;
+    TabNode* op = tab->parent;
+    if (op && op != folder)
+      [oldParents addObject:op];
+    [self detachNode:tab];
+    [folder->children addObject:tab];
+    tab->parent = folder;
+  }
+  folder->expanded = YES;
+  [self updateFolderTitle:folder];
+  for (TabNode* op in oldParents)
+    [self pruneFolder:op];
+  [self layoutTabRows];
+}
+
+- (void)addSelectionToBookmarksFromMenu:(id)sender {
+  NSArray<TabNode*>* ordered = [self selectionInFlatOrder];
+  if (ordered.count == 0)
+    return;
+  content::ShellContentBrowserClient* client =
+      content::ShellContentBrowserClient::Get();
+  base::DictValue bookmarks = client->GetBookmarks();
+  if (!bookmarks.contains("version"))
+    bookmarks.Set("version", 1);
+  base::ListValue* roots = bookmarks.EnsureList("roots");
+  for (TabNode* tab in ordered) {
+    if (!tab->shell)
+      continue;
+    GURL url = tab->shell->web_contents()->GetLastCommittedURL();
+    if (url.is_empty())
+      continue;
+    std::string title = base::UTF16ToUTF8(tab->shell->web_contents()->GetTitle());
+    base::DictValue entry;
+    entry.Set("type", "bookmark");
+    entry.Set("title", title);
+    entry.Set("url", url.spec());
+    roots->Append(std::move(entry));
+  }
+  client->SetBookmarks(std::move(bookmarks));
+  [self rebuildBookmarkBar];
+}
+
+- (void)closeFolderFromMenu:(id)sender {
+  TabNode* folder = [sender representedObject];
+  if (!folder || folder->kind != TabNodeKindFolder)
+    return;
+  NSMutableArray<TabNode*>* tabs = [NSMutableArray array];
+  [self collectTabsIn:folder->children into:tabs];
+  for (TabNode* tab in tabs)
+    if (tab->shell)
+      tab->shell->Close();
+}
