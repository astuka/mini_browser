+- (void)beginDragForNode:(TabNode*)node withEvent:(NSEvent*)event {
+  if (!node)
+    return;
+  _draggingNode = node;
+
+  NSPasteboardItem* item = [[NSPasteboardItem alloc] init];
+  [item setString:@"row" forType:kTabRowPasteboardType];
+  NSDraggingItem* dragItem =
+      [[NSDraggingItem alloc] initWithPasteboardWriter:item];
+
+  // Drag image: a snapshot of the row being dragged.
+  NSView* row = node->rowView;
+  NSRect bounds = row.bounds;
+  NSBitmapImageRep* rep = [row bitmapImageRepForCachingDisplayInRect:bounds];
+  [row cacheDisplayInRect:bounds toBitmapImageRep:rep];
+  NSImage* image = [[NSImage alloc] initWithSize:bounds.size];
+  [image addRepresentation:rep];
+  [dragItem setDraggingFrame:bounds contents:image];
+
+  [(TabRowView*)row beginDraggingSessionWithItems:@[ dragItem ]
+                                            event:event
+                                           source:(TabRowView*)row];
+}
+
+// Whether the in-flight drag can drop on `target`, and the highlight that goes
+// with it. Disallows dropping onto itself or into its own subtree.
+- (NSDragOperation)dragOverNode:(TabNode*)target {
+  if (!_draggingNode || !target || target == _draggingNode)
+    return NSDragOperationNone;
+  if ([self node:target isDescendantOf:_draggingNode])
+    return NSDragOperationNone;
+  if (_dropTargetNode != target) {
+    TabNode* prev = _dropTargetNode;
+    _dropTargetNode = target;
+    if (prev)
+      [self restyleRow:prev];
+    [self restyleRow:target];
+  }
+  return NSDragOperationMove;
+}
+
+- (void)dragExitedNode:(TabNode*)target {
+  if (_dropTargetNode == target) {
+    _dropTargetNode = nil;
+    [self restyleRow:target];
+  }
+}
+
+// Drop a row onto `target`. Onto a folder: move in. Onto a tab already in a
+// folder: join that folder next to it. Onto a top-level tab: create a new
+// folder holding both. Empties left behind in the source's old folder are
+// pruned.
+- (BOOL)performDropOnNode:(TabNode*)target {
+  TabNode* src = _draggingNode;
+  if (!src || !target || src == target)
+    return NO;
+  if ([self node:target isDescendantOf:src])
+    return NO;
+
+  TabNode* oldParent = src->parent;
+  TabNode* folder = nil;
+
+  if (target->kind == TabNodeKindFolder) {
+    folder = target;
+    [self detachNode:src];
+    [folder->children addObject:src];
+    src->parent = folder;
+  } else if (target->parent) {
+    folder = target->parent;
+    [self detachNode:src];
+    NSUInteger ti = [folder->children indexOfObject:target];
+    NSUInteger at = (ti == NSNotFound) ? folder->children.count : ti + 1;
+    [folder->children insertObject:src atIndex:at];
+    src->parent = folder;
+  } else {
+    // Top-level tab: wrap target and src in a new folder at target's slot.
+    // Detach src first so target's index reflects the post-removal positions.
+    folder = [self makeFolderNode];
+    [self detachNode:src];
+    NSUInteger ti = [_tabs indexOfObject:target];
+    if (ti == NSNotFound)
+      ti = _tabs.count;
+    [_tabs removeObject:target];
+    [_tabs insertObject:folder atIndex:ti];
+    [_sidebar addSubview:folder->rowView];
+    target->parent = folder;
+    src->parent = folder;
+    [folder->children addObject:target];
+    [folder->children addObject:src];
+  }
+
+  folder->expanded = YES;
+  if (oldParent && oldParent != folder)
+    [self pruneFolder:oldParent];
+  [self updateFolderTitle:folder];
+  [self layoutTabRows];
+  return YES;
+}
+
