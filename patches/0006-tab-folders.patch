+  TabTitleButton* title = [[TabTitleButton alloc] initWithFrame:NSZeroRect];
+  title.bordered = NO;
+  title.alignment = NSTextAlignmentLeft;
+  title.cell.lineBreakMode = NSLineBreakByTruncatingTail;
+  title.controller = self;
+  title.node = folder;
+  [row addSubview:title];
+  folder->titleButton = title;
+
+  return folder;
