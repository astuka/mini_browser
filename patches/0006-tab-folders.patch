+
+// Destination: forward all decisions to the controller, which owns the tree.
+- (NSDragOperation)draggingEntered:(id<NSDraggingInfo>)sender {
+  return [self.controller dragOverNode:self.node];
+}
+
+- (NSDragOperation)draggingUpdated:(id<NSDraggingInfo>)sender {
+  return [self.controller dragOverNode:self.node];
+}
+
+- (void)draggingExited:(id<NSDraggingInfo>)sender {
+  [self.controller dragExitedNode:self.node];
+}
+
+- (BOOL)prepareForDragOperation:(id<NSDraggingInfo>)sender {
+  return YES;
+}
+
+- (BOOL)performDragOperation:(id<NSDraggingInfo>)sender {
+  return [self.controller performDropOnNode:self.node];
+}
