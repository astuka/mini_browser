+// --- Tree helpers ----------------------------------------------------------
+
+// Every node in the tree, pre-order (includes folders and collapsed children).
+- (NSArray<TabNode*>*)allNodes {
+  NSMutableArray<TabNode*>* out = [NSMutableArray array];
+  [self collectNodes:_tabs into:out];
+  return out;
+}
+
+- (void)collectNodes:(NSArray<TabNode*>*)nodes
+                into:(NSMutableArray<TabNode*>*)out {
+  for (TabNode* node in nodes) {
+    [out addObject:node];
+    if (node->children)
+      [self collectNodes:node->children into:out];
+  }
+}
+
+- (NSInteger)depthOf:(TabNode*)node {
+  NSInteger depth = 0;
+  for (TabNode* p = node->parent; p; p = p->parent)
+    ++depth;
+  return depth;
+}
+
+- (BOOL)node:(TabNode*)node isDescendantOf:(TabNode*)ancestor {
+  for (TabNode* p = node; p; p = p->parent)
+    if (p == ancestor)
+      return YES;
+  return NO;
+}
+
+// Detaches a node from wherever it currently lives (a folder's children, or the
+// top-level roots), clearing its parent. Does not touch its row view.
+- (void)detachNode:(TabNode*)node {
+  NSMutableArray<TabNode*>* container = node->parent ? node->parent->children
+                                                     : _tabs;
+  [container removeObject:node];
+  node->parent = nil;
+}
+
+// Keeps folders meaningful: a folder with 2+ children just refreshes its label;
+// a folder that has dropped to 0 or 1 children is dissolved, with any lone
+// survivor lifted up into the folder's old position. Recurses upward, since
+// lifting a survivor can in turn empty a grandparent folder.
+- (void)pruneFolder:(TabNode*)folder {
+  if (!folder || folder->kind != TabNodeKindFolder)
+    return;
+  if (folder->children.count >= 2) {
+    [self updateFolderTitle:folder];
+    return;
+  }
+  NSMutableArray<TabNode*>* container = folder->parent ? folder->parent->children
+                                                       : _tabs;
+  NSUInteger at = [container indexOfObject:folder];
+  if (at == NSNotFound)
+    at = container.count;
+  TabNode* grand = folder->parent;
+  for (TabNode* child in [folder->children copy]) {
+    [container insertObject:child atIndex:at++];
+    child->parent = grand;
+  }
+  [folder->children removeAllObjects];
+  [container removeObject:folder];
+  [folder->rowView removeFromSuperview];
+  if (grand)
+    [self pruneFolder:grand];
+}
