+// --- Interstitials (S3) ----------------------------------------------------
+
+// Reusable interstitial: a full-content-area overlay with a centered card
+// (title, message, optional mono detail, and one or two buttons). The primary
+// button is the safe choice; the secondary (optional) is the risky one. Both
+// handlers run after the overlay is dismissed. Designed to be reused by later
+// security features (HTTPS-First, blocklist).
+- (void)presentInterstitialInTab:(TabNode*)tab
+                           title:(NSString*)title
+                         message:(NSString*)message
+                          detail:(NSString*)detail
+                     primaryText:(NSString*)primaryText
+                   secondaryText:(NSString*)secondaryText
+                       onPrimary:(void (^)(void))onPrimary
+                     onSecondary:(void (^)(void))onSecondary {
+  if (!tab)
+    return;
+  [self dismissInterstitialForTab:tab];
+
+  NSView* overlay = [[NSView alloc] initWithFrame:_contentContainer.bounds];
+  overlay.autoresizingMask = NSViewWidthSizable | NSViewHeightSizable;
+  overlay.wantsLayer = YES;
+  overlay.layer.backgroundColor = NSColor.windowBackgroundColor.CGColor;
+
+  const CGFloat cardW = 480;
+  const CGFloat cardH = 240;
+  NSView* card = [[NSView alloc]
+      initWithFrame:NSMakeRect((NSWidth(overlay.bounds) - cardW) / 2,
+                               (NSHeight(overlay.bounds) - cardH) / 2, cardW,
+                               cardH)];
+  card.autoresizingMask = NSViewMinXMargin | NSViewMaxXMargin |
+                          NSViewMinYMargin | NSViewMaxYMargin;
+  [overlay addSubview:card];
+
+  NSTextField* titleLabel = [NSTextField labelWithString:title];
+  titleLabel.font = [NSFont boldSystemFontOfSize:22];
+  titleLabel.frame = NSMakeRect(0, cardH - 34, cardW, 28);
+  [card addSubview:titleLabel];
+
+  NSTextField* msgLabel = [NSTextField wrappingLabelWithString:message];
+  msgLabel.preferredMaxLayoutWidth = cardW;
+  NSSize msgSize = [msgLabel sizeThatFits:NSMakeSize(cardW, CGFLOAT_MAX)];
+  msgLabel.frame =
+      NSMakeRect(0, cardH - 48 - msgSize.height, cardW, msgSize.height);
+  [card addSubview:msgLabel];
+
+  if (detail.length) {
+    NSTextField* detailLabel = [NSTextField wrappingLabelWithString:detail];
+    detailLabel.textColor = NSColor.secondaryLabelColor;
+    detailLabel.font = [NSFont monospacedSystemFontOfSize:11
+                                                   weight:NSFontWeightRegular];
+    detailLabel.preferredMaxLayoutWidth = cardW;
+    NSSize detailSize =
+        [detailLabel sizeThatFits:NSMakeSize(cardW, CGFLOAT_MAX)];
+    detailLabel.frame = NSMakeRect(0, 52, cardW, detailSize.height);
+    [card addSubview:detailLabel];
+  }
+
+  NSMutableArray* targets = [NSMutableArray array];
+
+  __weak TabbedShellController* weakSelf = self;
+  BlockTarget* primaryTarget = [[BlockTarget alloc] init];
+  primaryTarget.block = ^{
+    [weakSelf dismissInterstitialForTab:tab];
+    if (onPrimary)
+      onPrimary();
+  };
+  NSButton* primaryButton = [NSButton buttonWithTitle:primaryText
+                                               target:primaryTarget
+                                               action:@selector(fire:)];
+  primaryButton.keyEquivalent = @"\r";  // Default button (Enter).
+  [primaryButton sizeToFit];
+  CGFloat pbW = std::max(NSWidth(primaryButton.frame), CGFloat{120});
+  primaryButton.frame = NSMakeRect(cardW - pbW, 8, pbW, 32);
+  [card addSubview:primaryButton];
+  [targets addObject:primaryTarget];
+
+  if (secondaryText.length) {
+    BlockTarget* secondaryTarget = [[BlockTarget alloc] init];
+    secondaryTarget.block = ^{
+      [weakSelf dismissInterstitialForTab:tab];
+      if (onSecondary)
+        onSecondary();
+    };
+    NSButton* secondaryButton = [NSButton buttonWithTitle:secondaryText
+                                                   target:secondaryTarget
+                                                   action:@selector(fire:)];
+    [secondaryButton sizeToFit];
+    CGFloat sbW = std::max(NSWidth(secondaryButton.frame), CGFloat{120});
+    secondaryButton.frame = NSMakeRect(0, 8, sbW, 32);
+    [card addSubview:secondaryButton];
+    [targets addObject:secondaryTarget];
+  }
+
+  tab->interstitialView = overlay;
+  tab->interstitialTargets = targets;
+  [_contentContainer addSubview:overlay];
+  [self updateInterstitialVisibility];
+}
+
+- (void)dismissInterstitialForTab:(TabNode*)tab {
+  if (!tab)
+    return;
+  [tab->interstitialView removeFromSuperview];
+  tab->interstitialView = nil;
+  tab->interstitialTargets = nil;
+}
+
+// Only the active tab's interstitial should be visible, and it must sit above
+// the (re-raised) web view.
+- (void)updateInterstitialVisibility {
+  for (TabNode* node in [self allNodes]) {
+    if (!node->interstitialView)
+      continue;
+    BOOL active = (node == _activeTab);
+    node->interstitialView.hidden = !active;
+    if (active)
+      [_contentContainer addSubview:node->interstitialView
+                         positioned:NSWindowAbove
+                         relativeTo:nil];
+  }
+}
