+// static
+void ShellPlatformDelegate::RequestCertificateErrorDecision(
+    WebContents* web_contents,
+    const GURL& url,
+    int cert_error,
+    base::OnceCallback<void(bool)> callback) {
+  // Wrap the move-only callback in a block so the AppKit UI can run it once.
+  __block base::OnceCallback<void(bool)> cb = std::move(callback);
+  void (^resolve)(BOOL) = ^(BOOL proceed) {
+    if (cb)
+      std::move(cb).Run(proceed);
+  };
+  Shell* shell = Shell::FromWebContents(web_contents);
+  if (!shell || !g_tab_controller) {
+    resolve(NO);  // Fail safe (block) if there's no UI to ask in.
+    return;
+  }
+  [g_tab_controller presentCertErrorForShell:shell
+                                         url:url
+                                   certError:cert_error
+                                   onResolve:resolve];
+}
