+void ShellContentBrowserClient::AllowCertificateError(
+    WebContents* web_contents,
+    int cert_error,
+    const net::SSLInfo& ssl_info,
+    const GURL& request_url,
+    bool is_primary_main_frame_request,
+    bool strict_enforcement,
+    base::OnceCallback<void(CertificateRequestResultType)> callback) {
+#if BUILDFLAG(IS_MAC)
+  // For a top-level navigation, hand the decision to a real interstitial in the
+  // UI (Back to safety vs. Proceed). content_shell's default would just block.
+  if (is_primary_main_frame_request) {
+    auto on_decision = base::BindOnce(
+        [](base::OnceCallback<void(CertificateRequestResultType)> cb,
+           bool proceed) {
+          std::move(cb).Run(proceed ? CERTIFICATE_REQUEST_RESULT_TYPE_CONTINUE
+                                    : CERTIFICATE_REQUEST_RESULT_TYPE_CANCEL);
+        },
+        std::move(callback));
+    ShellPlatformDelegate::RequestCertificateErrorDecision(
+        web_contents, request_url, cert_error, std::move(on_decision));
+    return;
+  }
+#endif
+  // Subresource cert errors (and non-Mac builds): block.
+  std::move(callback).Run(CERTIFICATE_REQUEST_RESULT_TYPE_CANCEL);
+}
