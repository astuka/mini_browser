+// Builds and shows the certificate-error interstitial; `resolve(YES)` proceeds,
+// `resolve(NO)` goes back to safety (cancels the navigation).
+- (void)presentCertErrorForShell:(content::Shell*)shell
+                             url:(const GURL&)url
+                       certError:(int)certError
+                       onResolve:(void (^)(BOOL proceed))resolve {
+  TabNode* tab = shell ? [self tabForShell:shell] : nil;
+  if (!tab) {
+    if (resolve)
+      resolve(NO);  // No UI to show it in — fail safe.
+    return;
+  }
+  NSString* host = base::SysUTF8ToNSString(url.host());
+  NSString* title = @"Your connection is not private";
+  NSString* message = [NSString
+      stringWithFormat:@"%@ presented a certificate that couldn't be verified. "
+                       @"Someone may be impersonating the site to steal your "
+                       @"information.",
+                       host.length ? host : @"This site"];
+  NSString* detail =
+      [NSString stringWithFormat:@"net certificate error code: %d", certError];
+  [self presentInterstitialInTab:tab
+                           title:title
+                         message:message
+                          detail:detail
+                     primaryText:@"Back to safety"
+                   secondaryText:@"Proceed anyway (unsafe)"
+                       onPrimary:^{
+                         if (resolve)
+                           resolve(NO);
+                       }
+                     onSecondary:^{
+                       if (resolve)
+                         resolve(YES);
+                     }];
+}
