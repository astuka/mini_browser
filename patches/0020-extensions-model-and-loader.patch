+#pragma mark - Extensions (Graft epic, E1)
+
+// Derive an extension id from its on-disk path, mirroring Chrome's scheme for
+// unpacked extensions: SHA-256 of the path, take the first 16 bytes, and map
+// each nibble to the letters 'a'..'p' (giving a 32-char id). Deterministic per
+// path, so re-loading the same folder updates the same entry.
+- (NSString*)extensionIdForPath:(NSString*)path {
+  std::string hash =
+      crypto::SHA256HashString(base::SysNSStringToUTF8(path));
+  NSMutableString* extId = [NSMutableString stringWithCapacity:32];
+  for (int i = 0; i < 16; ++i) {
+    uint8_t byte = static_cast<uint8_t>(hash[i]);
+    [extId appendFormat:@"%c", 'a' + ((byte >> 4) & 0xf)];
+    [extId appendFormat:@"%c", 'a' + (byte & 0xf)];
+  }
+  return extId;
+}
