+// Read and parse <dir>/manifest.json, validate the MV3 essentials, and register
+// the extension in our persisted store. No execution happens in E1 — this only
+// records what the extension *is*.
+- (void)installExtensionFromDirectory:(NSString*)dir {
+  // Reading the manifest is a small, synchronous, user-initiated file read on
+  // the UI thread (the user just picked the folder in an open panel), so allow
+  // blocking here. content_shell is a test shell; a future PR that serves
+  // chrome-extension:// resources will move file I/O off-thread properly.
+  base::ScopedAllowBlockingForTesting allow_blocking;
+  NSString* manifestPath =
+      [dir stringByAppendingPathComponent:@"manifest.json"];
+  std::string contents;
+  base::FilePath fp(base::SysNSStringToUTF8(manifestPath));
+  if (!base::ReadFileToString(fp, &contents)) {
+    [self showExtensionError:@"That folder has no readable manifest.json."];
+    return;
+  }
+  std::optional<base::Value> parsed = base::JSONReader::Read(
+      contents, base::JSON_PARSE_CHROMIUM_EXTENSIONS);
+  if (!parsed || !parsed->is_dict()) {
+    [self showExtensionError:@"manifest.json is not valid JSON."];
+    return;
+  }
+  const base::DictValue& manifest = parsed->GetDict();
+  const std::string* name = manifest.FindString("name");
+  const std::string* version = manifest.FindString("version");
+  if (!name || !version) {
+    [self showExtensionError:
+              @"manifest.json is missing a \"name\" or \"version\"."];
+    return;
+  }
+
+  base::DictValue entry;
+  entry.Set("path", base::SysNSStringToUTF8(dir));
+  entry.Set("name", *name);
+  entry.Set("version", *version);
+  if (const std::string* desc = manifest.FindString("description"))
+    entry.Set("description", *desc);
+  if (std::optional<int> mv = manifest.FindInt("manifest_version"))
+    entry.Set("manifest_version", *mv);
+  entry.Set("enabled", true);
+  if (const base::ListValue* perms = manifest.FindList("permissions"))
+    entry.Set("permissions", perms->Clone());
+  if (const base::ListValue* hosts = manifest.FindList("host_permissions"))
+    entry.Set("host_permissions", hosts->Clone());
+
+  NSString* extId = [self extensionIdForPath:dir];
+  content::ShellContentBrowserClient* client =
+      content::ShellContentBrowserClient::Get();
+  base::DictValue extensions = client->GetExtensions();
+  extensions.Set(base::SysNSStringToUTF8(extId), std::move(entry));
+  client->SetExtensions(std::move(extensions));
+  [self rebuildExtensionsList];
+}
+
+- (void)loadUnpackedExtension:(id)sender {
+  NSOpenPanel* panel = [NSOpenPanel openPanel];
+  panel.canChooseFiles = NO;
+  panel.canChooseDirectories = YES;
+  panel.allowsMultipleSelection = NO;
+  panel.prompt = @"Load";
+  panel.message = @"Choose an unpacked extension folder (with a manifest.json)";
+  NSWindow* host = _extensionsPanel ?: _window;
+  __weak TabbedShellController* weakSelf = self;
+  void (^handler)(NSModalResponse) = ^(NSModalResponse result) {
+    if (result != NSModalResponseOK || panel.URLs.count == 0)
+      return;
+    [weakSelf installExtensionFromDirectory:panel.URLs.firstObject.path];
+  };
+  if (host)
+    [panel beginSheetModalForWindow:host completionHandler:handler];
+  else
+    handler([panel runModal]);
+}
+
+- (void)toggleExtensionEnabled:(NSButton*)sender {
+  NSString* extId = sender.identifier;
+  if (!extId.length)
+    return;
+  content::ShellContentBrowserClient* client =
+      content::ShellContentBrowserClient::Get();
+  base::DictValue extensions = client->GetExtensions();
+  if (base::DictValue* e =
+          extensions.FindDict(base::SysNSStringToUTF8(extId))) {
+    e->Set("enabled", sender.state == NSControlStateValueOn);
+    client->SetExtensions(std::move(extensions));
+  }
+  [self rebuildExtensionsList];
+}
+
+- (void)removeExtension:(NSButton*)sender {
+  NSString* extId = sender.identifier;
+  if (!extId.length)
+    return;
+  content::ShellContentBrowserClient* client =
+      content::ShellContentBrowserClient::Get();
+  base::DictValue extensions = client->GetExtensions();
+  extensions.Remove(base::SysNSStringToUTF8(extId));
+  client->SetExtensions(std::move(extensions));
+  [self rebuildExtensionsList];
+}
