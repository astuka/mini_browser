+// A non-editable, borderless label used in the extensions list.
+- (NSTextField*)makeExtLabel:(NSString*)text frame:(NSRect)frame {
+  NSTextField* label = [[NSTextField alloc] initWithFrame:frame];
+  label.stringValue = text;
+  label.editable = NO;
+  label.selectable = NO;
+  label.bordered = NO;
+  label.drawsBackground = NO;
+  label.font = [NSFont systemFontOfSize:11];
+  label.textColor = NSColor.secondaryLabelColor;
+  label.lineBreakMode = NSLineBreakByTruncatingTail;
+  return label;
+}
+
+// Rebuild the rows in the extensions list from the persisted store.
+- (void)rebuildExtensionsList {
+  if (!_extensionsListView)
+    return;
+  for (NSView* sub in [_extensionsListView.subviews copy])
+    [sub removeFromSuperview];
+
+  base::DictValue extensions =
+      content::ShellContentBrowserClient::Get()->GetExtensions();
+  CGFloat width = NSWidth(_extensionsListView.frame);
+  CGFloat y = 0;
+
+  if (extensions.empty()) {
+    NSTextField* empty = [self
+        makeExtLabel:@"No extensions loaded. Click “Load Unpacked…” below."
+               frame:NSMakeRect(16, 16, width - 32, 20)];
+    [_extensionsListView addSubview:empty];
+    y = 52;
+  } else {
+    const CGFloat rowH = 76;
+    for (auto&& [idKey, value] : extensions) {
+      if (!value.is_dict())
+        continue;
+      const base::DictValue& e = value.GetDict();
+      NSString* extId = base::SysUTF8ToNSString(idKey);
+      const std::string* name = e.FindString("name");
+      const std::string* version = e.FindString("version");
+      const std::string* desc = e.FindString("description");
+      const std::string* path = e.FindString("path");
+      bool enabled = e.FindBool("enabled").value_or(true);
+
+      // Enable/disable checkbox.
+      NSButton* check = [NSButton checkboxWithTitle:@""
+                                             target:self
+                                             action:@selector
+                                             (toggleExtensionEnabled:)];
+      check.state = enabled ? NSControlStateValueOn : NSControlStateValueOff;
+      check.frame = NSMakeRect(14, y + 12, 18, 18);
+      check.identifier = extId;
+      [_extensionsListView addSubview:check];
+
+      // Name + version (bold; dimmed when disabled).
+      NSString* nm = name ? base::SysUTF8ToNSString(*name) : @"(unknown)";
+      NSString* ver = version ? base::SysUTF8ToNSString(*version) : @"?";
+      NSTextField* titleLabel = [self
+          makeExtLabel:[NSString stringWithFormat:@"%@  v%@", nm, ver]
+                 frame:NSMakeRect(40, y + 8, width - 140, 18)];
+      titleLabel.font = [NSFont boldSystemFontOfSize:13];
+      titleLabel.textColor =
+          enabled ? NSColor.labelColor : NSColor.tertiaryLabelColor;
+      [_extensionsListView addSubview:titleLabel];
+
+      // Description (if any).
+      if (desc && !desc->empty()) {
+        NSTextField* descLabel =
+            [self makeExtLabel:base::SysUTF8ToNSString(*desc)
+                         frame:NSMakeRect(40, y + 28, width - 60, 16)];
+        [_extensionsListView addSubview:descLabel];
+      }
+
+      // Extension id + path (small, gray).
+      NSString* pathStr = path ? base::SysUTF8ToNSString(*path) : @"";
+      NSTextField* metaLabel = [self
+          makeExtLabel:[NSString stringWithFormat:@"%@ · %@", extId, pathStr]
+                 frame:NSMakeRect(40, y + 46, width - 60, 16)];
+      metaLabel.font = [NSFont monospacedSystemFontOfSize:9
+                                                   weight:NSFontWeightRegular];
+      metaLabel.textColor = NSColor.tertiaryLabelColor;
+      [_extensionsListView addSubview:metaLabel];
+
+      // Remove button.
+      NSButton* rm = [NSButton buttonWithTitle:@"Remove"
+                                        target:self
+                                        action:@selector(removeExtension:)];
+      rm.frame = NSMakeRect(width - 92, y + 12, 80, 24);
+      rm.bezelStyle = NSBezelStyleRounded;
+      rm.controlSize = NSControlSizeSmall;
+      rm.identifier = extId;
+      rm.autoresizingMask = NSViewMinXMargin;
+      [_extensionsListView addSubview:rm];
+
+      // Separator.
+      NSBox* sep = [[NSBox alloc]
+          initWithFrame:NSMakeRect(12, y + rowH - 1, width - 24, 1)];
+      sep.boxType = NSBoxSeparator;
+      sep.autoresizingMask = NSViewWidthSizable;
+      [_extensionsListView addSubview:sep];
+
+      y += rowH;
+    }
+  }
+
+  // Size the flipped document view so the scroll view scrolls correctly.
+  CGFloat minH = _extensionsListView.enclosingScrollView
+                     ? NSHeight(_extensionsListView.enclosingScrollView
+                                    .contentView.bounds)
+                     : y;
+  _extensionsListView.frame =
+      NSMakeRect(0, 0, width, MAX(y, minH));
+}
+
+// Shown via ⌘⇧E. A simple management window: load unpacked extensions,
+// enable/disable, and remove. No execution yet (E1 of the Graft epic).
+- (void)showExtensionsManager {
+  if (!_extensionsPanel) {
+    NSRect frame = NSMakeRect(0, 0, 480, 440);
+    _extensionsPanel = [[NSWindow alloc]
+        initWithContentRect:frame
+                  styleMask:(NSWindowStyleMaskTitled |
+                             NSWindowStyleMaskClosable |
+                             NSWindowStyleMaskResizable)
+                    backing:NSBackingStoreBuffered
+                      defer:NO];
+    _extensionsPanel.title = @"Extensions";
+    _extensionsPanel.releasedWhenClosed = NO;
+    [_extensionsPanel setFrameAutosaveName:@"MiniBrowserExtensionsPanel"];
+
+    NSView* contentView = _extensionsPanel.contentView;
+
+    NSButton* loadBtn =
+        [NSButton buttonWithTitle:@"Load Unpacked…"
+                           target:self
+                           action:@selector(loadUnpackedExtension:)];
+    loadBtn.frame = NSMakeRect(12, 12, 150, 30);
+    loadBtn.bezelStyle = NSBezelStyleRounded;
+    loadBtn.autoresizingMask = NSViewMaxXMargin | NSViewMaxYMargin;
+    [contentView addSubview:loadBtn];
+
+    NSScrollView* scroll = [[NSScrollView alloc]
+        initWithFrame:NSMakeRect(0, 54, frame.size.width,
+                                 frame.size.height - 54)];
+    scroll.hasVerticalScroller = YES;
+    scroll.borderType = NSNoBorder;
+    scroll.drawsBackground = NO;
+    scroll.autoresizingMask = NSViewWidthSizable | NSViewHeightSizable;
+    _extensionsListView = [[FlippedView alloc]
+        initWithFrame:NSMakeRect(0, 0, frame.size.width, 100)];
+    _extensionsListView.autoresizingMask = NSViewWidthSizable;
+    scroll.documentView = _extensionsListView;
+    [contentView addSubview:scroll];
+
+    [_extensionsPanel center];
+  }
+  [self rebuildExtensionsList];
+  [_extensionsPanel makeKeyAndOrderFront:nil];
+}
