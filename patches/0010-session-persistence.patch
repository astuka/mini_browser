+// --- Session persistence ---------------------------------------------------
+
+// Serializes the tab tree to the saved-session pref. No-op while restoring or
+// during the startup window (see _suppressSave) and during a full window close
+// (we want the last good session to survive a quit, not be cleared).
+- (void)saveSession {
+  if (_suppressSave || _restoring || _closingAll)
+    return;
+  base::DictValue session;
+  session.Set("version", 1);
+  session.Set("roots", [self serializeNodes:_tabs]);
+  content::ShellContentBrowserClient::Get()->SetSession(std::move(session));
+}
+
+- (base::ListValue)serializeNodes:(NSArray<TabNode*>*)nodes {
+  base::ListValue list;
+  for (TabNode* node in nodes) {
+    base::DictValue dict;
+    if (node->kind == TabNodeKindFolder) {
+      dict.Set("type", "folder");
+      dict.Set("title", base::SysNSStringToUTF8(
+                            node->folderTitle.length ? node->folderTitle
+                                                     : @"Folder"));
+      dict.Set("expanded", static_cast<bool>(node->expanded));
+      dict.Set("children", [self serializeNodes:node->children]);
+    } else {
+      dict.Set("type", "tab");
+      std::string url;
+      std::string title;
+      if (node->shell) {
+        url = node->shell->web_contents()->GetLastCommittedURL().spec();
+        title = base::UTF16ToUTF8(node->shell->web_contents()->GetTitle());
+      }
+      dict.Set("url", url);
+      dict.Set("title", title);
+      if (node == _activeTab)
+        dict.Set("active", true);
+    }
+    list.Append(std::move(dict));
+  }
+  return list;
+}
+
+// Recreates the saved tree under `parent` (nil = top level). Tabs become real
+// Shells (which append themselves at top level via addTabForShell), then get
+// re-parented into their folder.
+- (void)restoreNodes:(const base::ListValue&)nodes
+          intoFolder:(TabNode*)parent
+             context:(content::BrowserContext*)context {
+  for (const base::Value& item : nodes) {
+    const base::DictValue* dict = item.GetIfDict();
+    if (!dict)
+      continue;
+    const std::string* type = dict->FindString("type");
+    if (!type)
+      continue;
+
+    if (*type == "folder") {
+      TabNode* folder = [self makeFolderNode];
+      const std::string* title = dict->FindString("title");
+      if (title && !title->empty())
+        folder->folderTitle = base::SysUTF8ToNSString(*title);
+      folder->expanded = dict->FindBool("expanded").value_or(true);
+      if (parent) {
+        folder->parent = parent;
+        [parent->children addObject:folder];
+      } else {
+        [_tabs addObject:folder];
+      }
+      [_sidebar addSubview:folder->rowView];
+      if (const base::ListValue* children = dict->FindList("children"))
+        [self restoreNodes:*children intoFolder:folder context:context];
+      [self updateFolderTitle:folder];  // After children, so the count is right.
+    } else {
+      const std::string* url = dict->FindString("url");
+      std::string spec = (url && !url->empty()) ? *url : "about:blank";
+      content::Shell* shell = content::Shell::CreateNewWindow(
+          context, GURL(spec), nullptr, content::Shell::GetShellDefaultSize());
+      TabNode* node = [self tabForShell:shell];
+      if (!node)
+        continue;
+      if (parent) {
+        [self detachNode:node];  // Move out of the top-level roots.
+        node->parent = parent;
+        [parent->children addObject:node];
+      }
+      if (dict->FindBool("active").value_or(false))
+        _restoreActiveTab = node;
+    }
+  }
+}
+
+// Runs once, shortly after the first (placeholder) window comes up. Rebuilds the
+// previous session's tabs/folders, then disposes of the placeholder unless the
+// user explicitly launched with a URL.
+- (void)restoreSessionWithPlaceholder:(content::Shell*)placeholder {
+  base::DictValue session =
+      content::ShellContentBrowserClient::Get()->GetSession();
+  const base::ListValue* roots = session.FindList("roots");
+
+  if (roots && !roots->empty() && placeholder &&
+      placeholder->web_contents()) {
+    content::BrowserContext* context =
+        placeholder->web_contents()->GetBrowserContext();
+    _restoreActiveTab = nil;
+    _restoring = YES;
+    [self restoreNodes:*roots intoFolder:nil context:context];
+
+    TabNode* toActivate = _restoreActiveTab;
+    _restoreActiveTab = nil;
+    if (!toActivate) {
+      [self rebuildFlatRows];
+      for (TabNode* node in _flatRows) {
+        if (node->kind == TabNodeKindTab) {
+          toActivate = node;
+          break;
+        }
+      }
+    }
+    if (toActivate)
+      [self activateTab:toActivate];
+
+    // The placeholder is the default startup page unless a URL was given on the
+    // command line; in the default case, drop it so only the restored tabs show.
+    BOOL launchedWithURL =
+        !base::CommandLine::ForCurrentProcess()->GetArgs().empty();
+    if (!launchedWithURL) {
+      TabNode* placeholderNode = [self tabForShell:placeholder];
+      if (placeholderNode && placeholderNode->shell)
+        placeholderNode->shell->Close();  // -> removeTabForShell:
+    }
+    _restoring = NO;
+    [self layoutTabRows];
+  }
+
+  // Begin persisting from here on, capturing the now-current state.
+  _suppressSave = NO;
+  [self saveSession];
+}
