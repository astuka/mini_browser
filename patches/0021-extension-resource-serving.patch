new file mode 100644
index 0000000000..7933196c4a
--- /dev/null
+++ b/content/shell/browser/shell_extension_url_loader_factory.cc
@@ -0,0 +1,218 @@
+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/shell/browser/shell_extension_url_loader_factory.h"
+
+#include <string>
+#include <string_view>
+#include <utility>
+
+#include "base/files/file_path.h"
+#include "base/files/file_util.h"
+#include "base/functional/bind.h"
+#include "base/strings/escape.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/task/thread_pool.h"
+#include "base/values.h"
+#include "content/shell/browser/shell_content_browser_client.h"
+#include "mojo/public/cpp/bindings/remote.h"
+#include "mojo/public/cpp/system/data_pipe_producer.h"
+#include "mojo/public/cpp/system/string_data_source.h"
+#include "net/base/mime_util.h"
+#include "net/base/net_errors.h"
+#include "net/http/http_response_headers.h"
+#include "net/http/http_version.h"
+#include "services/network/public/cpp/resource_request.h"
+#include "services/network/public/mojom/url_loader.mojom.h"
+#include "services/network/public/mojom/url_response_head.mojom.h"
+
+namespace content {
+
+namespace {
+
+// The result of resolving + reading an extension resource off-thread.
+struct FileResult {
+  net::Error error = net::ERR_FAILED;
+  std::string data;
+  std::string mime_type;
+};
+
+// Looks up the on-disk root for `extension_id` in the persisted extensions
+// store. Must run on the UI thread (touches PrefService). Returns an empty path
+// if the extension isn't installed.
+base::FilePath RootForExtension(const std::string& extension_id) {
+  base::DictValue extensions =
+      ShellContentBrowserClient::Get()->GetExtensions();
+  const base::DictValue* entry = extensions.FindDict(extension_id);
+  if (!entry) {
+    return base::FilePath();
+  }
+  const std::string* path = entry->FindString("path");
+  if (!path) {
+    return base::FilePath();
+  }
+  return base::FilePath::FromUTF8Unsafe(*path);
+}
+
+// Resolves `relative_path` against the extension `root`, reads the file, and
+// guesses its MIME type. Runs on a MayBlock thread pool task. Rejects any path
+// that escapes the extension root (e.g. via "..").
+FileResult ReadExtensionResource(base::FilePath root,
+                                 std::string relative_path) {
+  FileResult result;
+
+  base::FilePath root_abs = base::MakeAbsoluteFilePath(root);
+  if (root_abs.empty()) {
+    result.error = net::ERR_FILE_NOT_FOUND;
+    return result;
+  }
+
+  if (relative_path.empty()) {
+    // No directory listing — a bare "chrome-extension://<id>/" has no resource.
+    result.error = net::ERR_FILE_NOT_FOUND;
+    return result;
+  }
+
+  base::FilePath candidate =
+      root_abs.Append(base::FilePath::FromUTF8Unsafe(relative_path));
+  base::FilePath resolved = base::MakeAbsoluteFilePath(candidate);
+  if (resolved.empty()) {
+    result.error = net::ERR_FILE_NOT_FOUND;
+    return result;
+  }
+
+  // Security: the resolved file must live inside the extension root.
+  if (root_abs != resolved && !root_abs.IsParent(resolved)) {
+    result.error = net::ERR_ACCESS_DENIED;
+    return result;
+  }
+
+  if (!base::ReadFileToString(resolved, &result.data)) {
+    result.error = net::ERR_FILE_NOT_FOUND;
+    return result;
+  }
+
+  if (!net::GetMimeTypeFromFile(resolved, &result.mime_type)) {
+    result.mime_type = "application/octet-stream";
+  }
+  result.error = net::OK;
+  return result;
+}
+
+// Holds the producer + client alive while the response body is streamed.
+struct WriteData {
+  mojo::Remote<network::mojom::URLLoaderClient> client;
+  std::string data;
+  std::unique_ptr<mojo::DataPipeProducer> producer;
+};
+
+void OnWrite(std::unique_ptr<WriteData> write_data, MojoResult result) {
+  if (result != MOJO_RESULT_OK) {
+    write_data->client->OnComplete(
+        network::URLLoaderCompletionStatus(net::ERR_FAILED));
+    return;
+  }
+  network::URLLoaderCompletionStatus status(net::OK);
+  status.encoded_data_length = write_data->data.size();
+  status.encoded_body_length = write_data->data.size();
+  status.decoded_body_length = write_data->data.size();
+  write_data->client->OnComplete(status);
+}
+
+// Builds and sends the response on the UI thread once the file has been read.
+void OnResourceRead(mojo::Remote<network::mojom::URLLoaderClient> client,
+                    FileResult result) {
+  if (result.error != net::OK) {
+    client->OnComplete(network::URLLoaderCompletionStatus(result.error));
+    return;
+  }
+
+  std::string content_length = base::NumberToString(result.data.size());
+  auto response = network::mojom::URLResponseHead::New();
+  response->mime_type = result.mime_type;
+  response->headers =
+      net::HttpResponseHeaders::Builder(net::HttpVersion(1, 1), "200 OK")
+          .AddHeader("Content-Type", result.mime_type)
+          .AddHeader("Content-Length", content_length)
+          .Build();
+  response->content_length = result.data.size();
+
+  mojo::ScopedDataPipeProducerHandle producer;
+  mojo::ScopedDataPipeConsumerHandle consumer;
+  if (CreateDataPipe(nullptr, producer, consumer) != MOJO_RESULT_OK) {
+    client->OnComplete(
+        network::URLLoaderCompletionStatus(net::ERR_INSUFFICIENT_RESOURCES));
+    return;
+  }
+
+  client->OnReceiveResponse(std::move(response), std::move(consumer),
+                            std::nullopt);
+
+  auto write_data = std::make_unique<WriteData>();
+  write_data->client = std::move(client);
+  write_data->data = std::move(result.data);
+  write_data->producer =
+      std::make_unique<mojo::DataPipeProducer>(std::move(producer));
+
+  mojo::DataPipeProducer* producer_ptr = write_data->producer.get();
+  std::string_view body(write_data->data);
+  producer_ptr->Write(
+      std::make_unique<mojo::StringDataSource>(
+          body, mojo::StringDataSource::AsyncWritingMode::
+                    STRING_STAYS_VALID_UNTIL_COMPLETION),
+      base::BindOnce(OnWrite, std::move(write_data)));
+}
+
+}  // namespace
+
+// static
+mojo::PendingRemote<network::mojom::URLLoaderFactory>
+ShellExtensionURLLoaderFactory::Create() {
+  mojo::PendingRemote<network::mojom::URLLoaderFactory> pending_remote;
+  // Self-deletes once all receivers disconnect.
+  new ShellExtensionURLLoaderFactory(
+      pending_remote.InitWithNewPipeAndPassReceiver());
+  return pending_remote;
+}
+
+ShellExtensionURLLoaderFactory::ShellExtensionURLLoaderFactory(
+    mojo::PendingReceiver<network::mojom::URLLoaderFactory> factory_receiver)
+    : network::SelfDeletingURLLoaderFactory(std::move(factory_receiver)) {}
+
+ShellExtensionURLLoaderFactory::~ShellExtensionURLLoaderFactory() = default;
+
+void ShellExtensionURLLoaderFactory::CreateLoaderAndStart(
+    mojo::PendingReceiver<network::mojom::URLLoader> loader,
+    int32_t request_id,
+    uint32_t options,
+    const network::ResourceRequest& request,
+    mojo::PendingRemote<network::mojom::URLLoaderClient> client,
+    const net::MutableNetworkTrafficAnnotationTag& traffic_annotation) {
+  mojo::Remote<network::mojom::URLLoaderClient> client_remote(std::move(client));
+
+  // chrome-extension://<id>/<path> — the host is the extension id.
+  const std::string extension_id(request.url.host());
+  base::FilePath root = RootForExtension(extension_id);
+  if (root.empty()) {
+    client_remote->OnComplete(
+        network::URLLoaderCompletionStatus(net::ERR_FILE_NOT_FOUND));
+    return;
+  }
+
+  // Strip the leading '/' and percent-decode the path. Any "../" traversal is
+  // caught later by the root-containment check in ReadExtensionResource.
+  std::string path(request.url.path());
+  if (!path.empty() && path.front() == '/') {
+    path.erase(0, 1);
+  }
+  std::string relative_path = base::UnescapeBinaryURLComponent(path);
+
+  base::ThreadPool::PostTaskAndReplyWithResult(
+      FROM_HERE, {base::MayBlock(), base::TaskPriority::USER_BLOCKING},
+      base::BindOnce(&ReadExtensionResource, std::move(root),
+                     std::move(relative_path)),
+      base::BindOnce(&OnResourceRead, std::move(client_remote)));
+}
+
+}  // namespace content
