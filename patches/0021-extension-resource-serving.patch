+mojo::PendingRemote<network::mojom::URLLoaderFactory>
+ShellContentBrowserClient::CreateNonNetworkNavigationURLLoaderFactory(
+    const std::string& scheme,
+    FrameTreeNodeId frame_tree_node_id) {
+  // Serve chrome-extension:// navigations (e.g. opening an extension page) from
+  // our extension resource server (Graft epic).
+  if (scheme == kShellExtensionScheme) {
+    return ShellExtensionURLLoaderFactory::Create();
+  }
+  return mojo::PendingRemote<network::mojom::URLLoaderFactory>();
+}
+
+void ShellContentBrowserClient::RegisterNonNetworkSubresourceURLLoaderFactories(
+    int render_process_id,
+    int render_frame_id,
+    const std::optional<url::Origin>& request_initiator_origin,
+    NonNetworkURLLoaderFactoryMap* factories) {
+  // Let extension pages load their own bundled subresources (icons, scripts,
+  // etc.) over chrome-extension://.
+  factories->emplace(kShellExtensionScheme,
+                     ShellExtensionURLLoaderFactory::Create());
+}
