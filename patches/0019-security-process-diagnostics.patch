+// --- Security diagnostics (S9) ----------------------------------------------
+
+// Reports the live process/sandbox/isolation posture — making the multiprocess,
+// sandboxed, site-isolated architecture content_shell inherits observable.
+- (NSString*)securityDiagnosticsText {
+  base::CommandLine* cl = base::CommandLine::ForCurrentProcess();
+  BOOL noSandbox = cl->HasSwitch("no-sandbox");
+  BOOL singleProcess = content::RenderProcessHost::run_renderer_in_process();
+  BOOL sitePerProcess =
+      content::SiteIsolationPolicy::UseDedicatedProcessesForAllSites();
+  BOOL isolatedOrigins =
+      content::SiteIsolationPolicy::AreIsolatedOriginsEnabled();
+
+  NSMutableString* s = [NSMutableString string];
+  [s appendFormat:@"Process model: %@\n",
+                  singleProcess ? @"single process"
+                                : @"multi-process (renderer per site instance)"];
+  [s appendFormat:@"Renderer sandbox: %@\n",
+                  noSandbox ? @"DISABLED (--no-sandbox)" : @"enabled"];
+  [s appendFormat:@"Site isolation (site-per-process): %@\n",
+                  sitePerProcess ? @"on" : @"off"];
+  [s appendFormat:@"Isolated origins: %@\n", isolatedOrigins ? @"on" : @"off"];
+
+  NSMutableSet<NSNumber*>* pids = [NSMutableSet set];
+  NSMutableString* rows = [NSMutableString string];
+  for (TabNode* node in [self allNodes]) {
+    if (node->kind != TabNodeKindTab || !node->shell)
+      continue;
+    content::RenderProcessHost* rph =
+        node->shell->web_contents()->GetPrimaryMainFrame()->GetProcess();
+    base::ProcessId pid = rph->GetProcess().Pid();
+    [pids addObject:@(pid)];
+    NSString* title =
+        node->titleButton.title.length ? node->titleButton.title : @"(untitled)";
+    [rows appendFormat:@"  • %@ — renderer pid %d\n", title, (int)pid];
+  }
+  [s appendFormat:@"\nRenderer processes in use: %lu\n",
+                  (unsigned long)pids.count];
+  [s appendString:@"\nTabs:\n"];
+  [s appendString:rows];
+  return s;
+}
+
+// Shown via ⌘⇧D. An informational sheet listing the diagnostics.
+- (void)showSecurityDiagnostics {
+  if (!_window)
+    return;
+  NSAlert* alert = [[NSAlert alloc] init];
+  alert.messageText = @"Security Diagnostics";
+  alert.informativeText = [self securityDiagnosticsText];
+  [alert addButtonWithTitle:@"OK"];
+  [alert beginSheetModalForWindow:_window
+                completionHandler:^(NSModalResponse response){
+                }];
+}
