+#if BUILDFLAG(IS_MAC)
+namespace {
+
+// Executable / installer file types we warn about before saving.
+bool IsDangerousFileType(const base::FilePath& path) {
+  std::string ext = base::ToLowerASCII(path.FinalExtension());
+  static const char* const kDangerous[] = {
+      ".dmg", ".pkg", ".app", ".exe",     ".scr", ".bat", ".cmd",
+      ".com", ".msi", ".jar", ".command", ".sh",  ".dylib"};
+  for (const char* d : kDangerous) {
+    if (ext == d)
+      return true;
+  }
+  return false;
+}
+
+// Completes the download to |path| (an empty path cancels the download).
+void RunTargetCallback(download::DownloadTargetCallback callback,
+                       const base::FilePath& path) {
+  download::DownloadTargetInfo target_info;
+  target_info.target_path = path;
+  if (!path.empty())
+    target_info.intermediate_path =
+        path.AddExtension(FILE_PATH_LITERAL(".crdownload"));
+  std::move(callback).Run(std::move(target_info));
+}
+
+void OnDownloadWarningDecision(download::DownloadTargetCallback callback,
+                               base::FilePath path,
+                               bool keep) {
+  RunTargetCallback(std::move(callback), keep ? path : base::FilePath());
+}
+
+}  // namespace
+#endif  // BUILDFLAG(IS_MAC)
