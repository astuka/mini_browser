+// Dangerous-download warning: a critical sheet with Keep / Discard.
+- (void)presentDownloadWarningForFilename:(NSString*)filename
+                                onResolve:(void (^)(BOOL keep))resolve {
+  if (!_window) {
+    if (resolve)
+      resolve(NO);
+    return;
+  }
+  NSAlert* alert = [[NSAlert alloc] init];
+  alert.alertStyle = NSAlertStyleCritical;
+  alert.messageText = @"This file might be dangerous";
+  alert.informativeText = [NSString
+      stringWithFormat:@"\"%@\" is an executable or installer that could harm "
+                       @"your computer. Keep it anyway?",
+                       filename];
+  [alert addButtonWithTitle:@"Keep"];
+  [alert addButtonWithTitle:@"Discard"];
+  [alert beginSheetModalForWindow:_window
+                completionHandler:^(NSModalResponse response) {
+                  if (resolve)
+                    resolve(response == NSAlertFirstButtonReturn);
+                }];
+}
