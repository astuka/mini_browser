+// static
+void ShellPlatformDelegate::RequestDownloadDecision(
+    WebContents* web_contents,
+    const std::string& filename,
+    base::OnceCallback<void(bool)> callback) {
+  __block base::OnceCallback<void(bool)> cb = std::move(callback);
+  void (^resolve)(BOOL) = ^(BOOL keep) {
+    if (cb)
+      std::move(cb).Run(keep);
+  };
+  if (!g_tab_controller) {
+    resolve(NO);  // No UI — fail safe (discard).
+    return;
+  }
+  [g_tab_controller
+      presentDownloadWarningForFilename:base::SysUTF8ToNSString(filename)
+                              onResolve:resolve];
+}
