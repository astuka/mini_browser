+void ShellRenderFrameObserver::ExecuteScript(const std::string& code,
+                                             int32_t world_id,
+                                             ExecuteScriptCallback callback) {
+  blink::WebLocalFrame* frame = render_frame()->GetWebFrame();
+  if (!frame) {
+    std::move(callback).Run(R"({"ok":false,"error":"no frame"})");
+    return;
+  }
+  v8::Isolate* isolate = v8::Isolate::GetCurrent();
+  v8::HandleScope handle_scope(isolate);
+
+  // Evaluate the caller's expression in the extension's isolated world and bring
+  // the value back as a JSON string (serialized in that world, so we never need
+  // its v8 context here). Errors are reported in the same envelope.
+  std::string wrapped =
+      "(function(){try{var r=(" + code +
+      ");return JSON.stringify({ok:true,result:(r===undefined?null:r)});}"
+      "catch(e){return "
+      "JSON.stringify({ok:false,error:String((e&&e.message)||e)});}})()";
+
+  v8::Local<v8::Value> result =
+      frame->ExecuteScriptInIsolatedWorldAndReturnValue(
+          world_id, blink::WebScriptSource(blink::WebString::FromUtf8(wrapped)),
+          blink::BackForwardCacheAware::kPossiblyDisallow);
+  if (result.IsEmpty() || !result->IsString()) {
+    std::move(callback).Run(R"({"ok":false,"error":"no result"})");
+    return;
+  }
+  v8::String::Utf8Value utf8(isolate, result);
+  std::move(callback).Run(*utf8 ? std::string(*utf8, utf8.length())
+                                : std::string());
+}
+
 }  // namespace content
