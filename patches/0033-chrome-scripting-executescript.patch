+  // chrome.scripting.executeScript (Wield W3): serialize the injected function
+  // (+ args) into an expression the browser runs in the target tab's frame, then
+  // shape the reply like chrome (an array of {frameId, result}). `files`/`world`
+  // aren't supported yet. activeTab needs no enforcement here (no host perms).
+  chrome.scripting = {
+    executeScript: function(injection, cb) {
+      injection = injection || {};
+      var target = injection.target || {};
+      var tabId = (typeof target.tabId === "number") ? target.tabId : -1;
+      var fn = injection.func || injection.function;
+      if (typeof fn !== "function") {
+        var empty = Promise.resolve([]);
+        if (typeof cb === "function") empty.then(cb);
+        return empty;
+      }
+      var code = "(" + fn.toString() + ").apply(null," +
+                 JSON.stringify(injection.args || []) + ")";
+      var p = __api.executeScript(tabId | 0, code).then(function(j) {
+        var env;
+        try { env = JSON.parse(j); } catch (e) { env = { ok: false, error: "parse" }; }
+        if (!env.ok) {
+          if (typeof cb === "function") cb([]);
+          return Promise.reject(new Error(env.error || "executeScript failed"));
+        }
+        var arr = [{ frameId: 0, result: env.result }];
+        if (typeof cb === "function") cb(arr);
+        return arr;
+      });
+      return p;
+    }
+  };
