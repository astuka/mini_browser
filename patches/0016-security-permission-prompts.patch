+// Permission prompt: a sheet with Allow / Block. Unlike the page-blocking
+// interstitials, a permission request is a transient dialog.
+- (void)presentPermissionPromptForShell:(content::Shell*)shell
+                                message:(NSString*)message
+                              onResolve:(void (^)(BOOL allow))resolve {
+  if (!_window) {
+    if (resolve)
+      resolve(NO);
+    return;
+  }
+  NSAlert* alert = [[NSAlert alloc] init];
+  alert.messageText = @"Permission request";
+  alert.informativeText = message;
+  [alert addButtonWithTitle:@"Allow"];
+  [alert addButtonWithTitle:@"Block"];
+  [alert beginSheetModalForWindow:_window
+                completionHandler:^(NSModalResponse response) {
+                  if (resolve)
+                    resolve(response == NSAlertFirstButtonReturn);
+                }];
+}
