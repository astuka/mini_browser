+std::optional<bool> ShellContentBrowserClient::GetSitePermission(
+    const std::string& origin,
+    const std::string& key) {
+  const base::DictValue& settings =
+      GetSharedState().local_state->GetDict(kSiteSettings);
+  const base::DictValue* origin_dict = settings.FindDict(origin);
+  if (!origin_dict)
+    return std::nullopt;
+  return origin_dict->FindBool(key);
+}
+
+void ShellContentBrowserClient::SetSitePermission(const std::string& origin,
+                                                  const std::string& key,
+                                                  bool allow) {
+  base::DictValue settings =
+      GetSharedState().local_state->GetDict(kSiteSettings).Clone();
+  settings.EnsureDict(origin)->Set(key, allow);
+  GetSharedState().local_state->SetDict(kSiteSettings, std::move(settings));
+  GetSharedState().local_state->CommitPendingWrite();
+}
