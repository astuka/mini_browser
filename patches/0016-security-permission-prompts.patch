+// Permissions we surface a real prompt for (instead of the test-shell's
+// auto-grant/deny). Everything else keeps the IsAllowlistedPermissionType
+// behavior.
+bool IsPromptablePermission(PermissionType permission) {
+  switch (permission) {
+    case PermissionType::GEOLOCATION:
+    case PermissionType::GEOLOCATION_APPROXIMATE:
+    case PermissionType::NOTIFICATIONS:
+    case PermissionType::AUDIO_CAPTURE:
+    case PermissionType::VIDEO_CAPTURE:
+    case PermissionType::CLIPBOARD_READ_WRITE:
+      return true;
+    default:
+      return false;
+  }
+}
+
+// Stable per-origin storage key for a promptable permission.
+std::string PermissionKey(PermissionType permission) {
+  switch (permission) {
+    case PermissionType::GEOLOCATION:
+    case PermissionType::GEOLOCATION_APPROXIMATE:
+      return "geolocation";
+    case PermissionType::NOTIFICATIONS:
+      return "notifications";
+    case PermissionType::AUDIO_CAPTURE:
+      return "microphone";
+    case PermissionType::VIDEO_CAPTURE:
+      return "camera";
+    case PermissionType::CLIPBOARD_READ_WRITE:
+      return "clipboard";
+    default:
+      return "other";
+  }
+}
+
+std::string PermissionPromptMessage(PermissionType permission,
+                                    const std::string& host) {
+  std::string what;
+  switch (permission) {
+    case PermissionType::GEOLOCATION:
+    case PermissionType::GEOLOCATION_APPROXIMATE:
+      what = "know your location";
+      break;
+    case PermissionType::NOTIFICATIONS:
+      what = "show notifications";
+      break;
+    case PermissionType::AUDIO_CAPTURE:
+      what = "use your microphone";
+      break;
+    case PermissionType::VIDEO_CAPTURE:
+      what = "use your camera";
+      break;
+    case PermissionType::CLIPBOARD_READ_WRITE:
+      what = "read from your clipboard";
+      break;
+    default:
+      what = "use a device feature";
+      break;
+  }
+  return "Allow " + (host.empty() ? std::string("this site") : host) + " to " +
+         what + "?";
+}
+
+std::string OriginKey(const GURL& url) {
+  return url::Origin::Create(url).Serialize();
+}
+
+// Builds a PermissionResult, preserving the GeolocationSetting that the
+// approximate-geolocation feature expects when granting geolocation.
+PermissionResult MakeResult(PermissionType type, bool allow) {
+  blink::mojom::PermissionStatus status =
+      allow ? blink::mojom::PermissionStatus::GRANTED
+            : blink::mojom::PermissionStatus::DENIED;
+  if (allow &&
+      (type == PermissionType::GEOLOCATION ||
+       type == PermissionType::GEOLOCATION_APPROXIMATE) &&
+      base::FeatureList::IsEnabled(
+          content_settings::features::kApproximateGeolocationPermission)) {
+    GeolocationSetting setting = {PermissionOption::kAllowed,
+                                  PermissionOption::kAllowed};
+    return PermissionResult(status, PermissionStatusSource::UNSPECIFIED,
+                            setting);
+  }
+  return PermissionResult(status);
+}
+
+// Resolves a list of permission requests one at a time — using a saved per-
+// origin decision when present, otherwise prompting the user (and saving the
+// answer). Self-owned: deletes itself once every permission is resolved.
+class PermissionPromptFlow {
+ public:
+  PermissionPromptFlow(
+      WebContents* web_contents,
+      std::string origin,
+      std::vector<PermissionType> types,
+      base::OnceCallback<void(const std::vector<PermissionResult>&)> callback)
+      : web_contents_(web_contents ? web_contents->GetWeakPtr() : nullptr),
+        origin_(std::move(origin)),
+        types_(std::move(types)),
+        callback_(std::move(callback)) {}
+
+  void Start() { ProcessNext(); }
+
+ private:
+  void ProcessNext() {
+    if (results_.size() >= types_.size()) {
+      std::move(callback_).Run(results_);
+      delete this;
+      return;
+    }
+    PermissionType type = types_[results_.size()];
+    if (!IsPromptablePermission(type)) {
+      results_.push_back(MakeResult(type, IsAllowlistedPermissionType(type)));
+      ProcessNext();
+      return;
+    }
+    std::string key = PermissionKey(type);
+    std::optional<bool> saved =
+        ShellContentBrowserClient::Get()->GetSitePermission(origin_, key);
+    if (saved.has_value()) {
+      results_.push_back(MakeResult(type, *saved));
+      ProcessNext();
+      return;
+    }
+#if BUILDFLAG(IS_MAC)
+    if (web_contents_) {
+      GURL origin_url(origin_);
+      ShellPlatformDelegate::RequestPermissionDecision(
+          web_contents_.get(),
+          PermissionPromptMessage(type, std::string(origin_url.host())),
+          base::BindOnce(&PermissionPromptFlow::OnDecision,
+                         base::Unretained(this), type, key));
+      return;
+    }
+#endif
+    results_.push_back(MakeResult(type, false));
+    ProcessNext();
+  }
+
+  void OnDecision(PermissionType type, std::string key, bool allow) {
+    ShellContentBrowserClient::Get()->SetSitePermission(origin_, key, allow);
+    results_.push_back(MakeResult(type, allow));
+    ProcessNext();
+  }
+
+  base::WeakPtr<WebContents> web_contents_;
+  std::string origin_;
+  std::vector<PermissionType> types_;
+  std::vector<PermissionResult> results_;
+  base::OnceCallback<void(const std::vector<PermissionResult>&)> callback_;
+};
