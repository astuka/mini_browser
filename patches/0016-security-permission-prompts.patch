+// static
+void ShellPlatformDelegate::RequestPermissionDecision(
+    WebContents* web_contents,
+    const std::string& message,
+    base::OnceCallback<void(bool)> callback) {
+  __block base::OnceCallback<void(bool)> cb = std::move(callback);
+  void (^resolve)(BOOL) = ^(BOOL allow) {
+    if (cb)
+      std::move(cb).Run(allow);
+  };
+  Shell* shell = Shell::FromWebContents(web_contents);
+  if (!shell || !g_tab_controller) {
+    resolve(NO);
+    return;
+  }
+  [g_tab_controller presentPermissionPromptForShell:shell
+                                            message:base::SysUTF8ToNSString(
+                                                        message)
+                                          onResolve:resolve];
+}
