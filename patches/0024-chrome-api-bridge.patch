+void ShellRenderFrameObserver::DidCreateScriptContext(
+    v8::Local<v8::Context> context,
+    int32_t world_id) {
+  // E5 installs the chrome.* shim only in extension pages' main world (popup,
+  // options, background). Content-script worlds get it once a browser-backed
+  // API bridge lands.
+  if (world_id != 0) {
+    return;
+  }
+  blink::WebLocalFrame* frame = render_frame()->GetWebFrame();
+  if (!frame) {
+    return;
+  }
+  GURL url = frame->GetDocument().Url();
+  if (!url.SchemeIs("chrome-extension") || url.host().empty()) {
+    return;
+  }
+
+  std::string shim = BuildChromeShim(std::string(url.host()));
+
+  v8::Isolate* isolate = v8::Isolate::GetCurrent();
+  v8::HandleScope handle_scope(isolate);
+  v8::Context::Scope context_scope(context);
+  v8::TryCatch try_catch(isolate);
+  v8::Local<v8::String> source;
+  if (!v8::String::NewFromUtf8(isolate, shim.c_str(),
+                               v8::NewStringType::kNormal, shim.size())
+           .ToLocal(&source)) {
+    return;
+  }
+  v8::Local<v8::Script> script;
+  if (!v8::Script::Compile(context, source).ToLocal(&script)) {
+    return;
+  }
+  v8::Local<v8::Value> result;
+  // Errors in the shim are non-fatal; just swallow them.
+  if (!script->Run(context).ToLocal(&result)) {
+    return;
+  }
+}
+
 }  // namespace content
