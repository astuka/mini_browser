+// --- Connection security (S1) ----------------------------------------------
+
+// Derives the security level for a tab from its current navigation. We compute
+// this ourselves from the URL scheme + SSLStatus, because content_shell has no
+// //components/security_state to hand us a precomputed level.
+- (SecurityLevel)securityLevelForShell:(content::Shell*)shell {
+  if (!shell || !shell->web_contents())
+    return SecurityLevelNone;
+  content::NavigationEntry* entry =
+      shell->web_contents()->GetController().GetVisibleEntry();
+  if (!entry)
+    return SecurityLevelNone;
+  const GURL& url = entry->GetURL();
+  if (url.SchemeIsCryptographic()) {  // https / wss
+    const content::SSLStatus& ssl = entry->GetSSL();
+    if (net::IsCertStatusError(ssl.cert_status))
+      return SecurityLevelDangerous;
+    if (ssl.content_status & (content::SSLStatus::DISPLAYED_INSECURE_CONTENT |
+                             content::SSLStatus::RAN_INSECURE_CONTENT))
+      return SecurityLevelMixed;
+    return SecurityLevelSecure;
+  }
+  if (url.SchemeIs("http"))
+    return SecurityLevelInsecure;
+  return SecurityLevelNone;  // about:, data:, file:, chrome-extension:, …
+}
+
+// Recomputes a tab's stored security level; refreshes the indicator if it's the
+// active tab.
+- (void)updateSecurityStateForShell:(content::Shell*)shell {
+  TabNode* tab = [self tabForShell:shell];
+  if (!tab)
+    return;
+  tab->securityLevel = [self securityLevelForShell:shell];
+  if (tab == _activeTab)
+    [self refreshSecurityIndicator];
+}
+
+// Paints the indicator from the active tab's level (icon + tint + tooltip).
+- (void)refreshSecurityIndicator {
+  if (_hideToolbar || !_securityIndicator)
+    return;
+  SecurityLevel level = _activeTab ? _activeTab->securityLevel : SecurityLevelNone;
+
+  NSString* symbol = nil;
+  NSColor* tint = nil;
+  NSString* tip = nil;
+  switch (level) {
+    case SecurityLevelSecure:
+      symbol = @"lock.fill";
+      tint = NSColor.systemGreenColor;
+      tip = @"Connection is secure (HTTPS)";
+      break;
+    case SecurityLevelMixed:
+      symbol = @"lock.open.fill";
+      tint = NSColor.systemYellowColor;
+      tip = @"HTTPS page with insecure content";
+      break;
+    case SecurityLevelDangerous:
+      symbol = @"exclamationmark.triangle.fill";
+      tint = NSColor.systemRedColor;
+      tip = @"Certificate error — connection is not private";
+      break;
+    case SecurityLevelInsecure:
+      symbol = @"exclamationmark.circle";
+      tint = NSColor.secondaryLabelColor;
+      tip = @"Not Secure (HTTP)";
+      break;
+    case SecurityLevelNone:
+      break;  // No indicator for internal/local pages.
+  }
+
+  if (!symbol) {
+    _securityIndicator.image = nil;
+    _securityIndicator.hidden = YES;
+    _securityIndicator.toolTip = nil;
+    return;
+  }
+  _securityIndicator.hidden = NO;
+  _securityIndicator.toolTip = tip;
+  if (@available(macOS 11.0, *)) {
+    NSImage* icon = [NSImage imageWithSystemSymbolName:symbol
+                              accessibilityDescription:tip];
+    _securityIndicator.image = icon;
+    _securityIndicator.contentTintColor = tint;
+  }
+}
