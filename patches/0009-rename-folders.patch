+// --- Folder rename ---------------------------------------------------------
+
+- (void)renameFolderFromMenu:(id)sender {
+  // Defer until the context menu has fully dismissed: starting the field editor
+  // while the menu is still tearing down is unreliable.
+  TabNode* folder = [sender representedObject];
+  dispatch_async(dispatch_get_main_queue(), ^{
+    [self beginRenameFolder:folder];
+  });
+}
+
+// Overlays an editable text field on the folder's row, seeded with the current
+// name (just the name — not the disclosure triangle or tab count).
+- (void)beginRenameFolder:(TabNode*)folder {
+  if (!folder || folder->kind != TabNodeKindFolder)
+    return;
+  if (_renameField)
+    [self cancelRename];  // Finish any rename already in flight.
+
+  _renamingFolder = folder;
+  _renameCancelled = NO;
+
+  CGFloat indent = [self depthOf:folder] * kIndent;
+  NSRect frame = NSMakeRect(indent, NSMinY(folder->rowView.frame),
+                            kSidebarWidth - indent, kTabRowHeight);
+  NSTextField* field = [[NSTextField alloc] initWithFrame:frame];
+  field.stringValue =
+      folder->folderTitle.length ? folder->folderTitle : @"Folder";
+  field.font = folder->titleButton.font;
+  field.editable = YES;
+  field.selectable = YES;
+  field.bezeled = YES;
+  field.target = self;
+  field.action = @selector(renameFieldAction:);
+  [_sidebar addSubview:field];
+  _renameField = field;
+  [_window makeFirstResponder:field];
+  [field selectText:nil];
+  // Attach the commit delegate only after the field has settled as first
+  // responder: AppKit emits a spurious end-editing *while* the field is
+  // becoming first responder, and handling it would tear the editor down
+  // before the user can type.
+  dispatch_async(dispatch_get_main_queue(), ^{
+    if (self->_renameField == field)
+      field.delegate = self;
+  });
+}
+
+// Return commits by ending editing (handled in controlTextDidEndEditing:).
+- (void)renameFieldAction:(id)sender {
+  [_window makeFirstResponder:nil];
+}
+
+- (void)cancelRename {
+  _renameCancelled = YES;
+  if (_renameField)
+    [_window makeFirstResponder:nil];  // Ends editing; the change is discarded.
+}
+
+// Single commit point for Return, blur, and Esc (via _renameCancelled).
+- (void)controlTextDidEndEditing:(NSNotification*)notification {
+  if (!_renamingFolder || !_renameField)
+    return;
+  TabNode* folder = _renamingFolder;
+  NSString* name = nil;
+  if (!_renameCancelled) {
+    name = [_renameField.stringValue
+        stringByTrimmingCharactersInSet:NSCharacterSet
+                                            .whitespaceAndNewlineCharacterSet];
+  }
+  [_renameField removeFromSuperview];
+  _renameField = nil;
+  _renamingFolder = nil;
+  _renameCancelled = NO;
+  if (name) {
+    folder->folderTitle = name.length ? name : @"Folder";
+    [self updateFolderTitle:folder];
+    [self layoutTabRows];
+  }
+}
+
+// Esc cancels the rename without saving.
+- (BOOL)control:(NSControl*)control
+               textView:(NSTextView*)textView
+    doCommandBySelector:(SEL)commandSelector {
+  // Esc cancels the rename. The field editor routes Escape through either of
+  // these selectors depending on context; both discard the edit.
+  if (commandSelector == @selector(cancelOperation:) ||
+      commandSelector == @selector(complete:)) {
+    [self cancelRename];
+    return YES;
+  }
+  return NO;
+}
