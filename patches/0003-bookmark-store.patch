+base::DictValue ShellContentBrowserClient::GetBookmarks() {
+  return GetSharedState().local_state->GetDict(kBookmarks).Clone();
+}
+
+void ShellContentBrowserClient::SetBookmarks(base::DictValue bookmarks) {
+  GetSharedState().local_state->SetDict(kBookmarks, std::move(bookmarks));
