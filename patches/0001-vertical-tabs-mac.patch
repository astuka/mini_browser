+- (BOOL)windowShouldClose:(id)sender {
+  // Closing the window closes every tab. Close()->~Shell()->removeTabForShell:
+  // is suppressed by _closingAll so we can tear down deterministically here.
+  _closingAll = YES;
+  NSArray<TabInfo*>* snapshot = [_tabs copy];
+  for (TabInfo* tab in snapshot) {
+    content::Shell* shell = tab->shell;
