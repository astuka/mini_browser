-- (TabInfo*)tabForShell:(content::Shell*)shell {
-  for (TabInfo* tab in _tabs) {
-    if (tab->shell == shell)
-      return tab;
+- (TabNode*)tabForShell:(content::Shell*)shell {
+  return [self findShell:shell in:_tabs];
+}
+
+- (TabNode*)findShell:(content::Shell*)shell in:(NSArray<TabNode*>*)nodes {
+  for (TabNode* node in nodes) {
+    if (node->kind == TabNodeKindTab && node->shell == shell)
+      return node;
+    if (node->children) {
+      TabNode* found = [self findShell:shell in:node->children];
+      if (found)
+        return found;
+    }
   }
   return nil;
 }
 
+// Total number of tab (non-folder) nodes anywhere in the tree.
+- (NSUInteger)tabNodeCount {
+  return [self countTabsIn:_tabs];
+}
+
+- (NSUInteger)countTabsIn:(NSArray<TabNode*>*)nodes {
+  NSUInteger count = 0;
+  for (TabNode* node in nodes) {
+    if (node->kind == TabNodeKindTab)
+      ++count;
+    if (node->children)
+      count += [self countTabsIn:node->children];
+  }
+  return count;
+}
+
