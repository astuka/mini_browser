 // Positions the New Tab button and all tab rows within the sidebar.
+// Rebuilds _flatRows as the visible top-to-bottom order: a pre-order DFS of the
+// tree that descends into expanded folders only. With no folders yet, this is
+// just a copy of _tabs.
+- (void)rebuildFlatRows {
+  [_flatRows removeAllObjects];
+  [self appendFlatRows:_tabs];
+}
+
+- (void)appendFlatRows:(NSArray<TabNode*>*)nodes {
+  for (TabNode* node in nodes) {
+    [_flatRows addObject:node];
+    if (node->kind == TabNodeKindFolder && node->expanded && node->children)
+      [self appendFlatRows:node->children];
+  }
+}
+
