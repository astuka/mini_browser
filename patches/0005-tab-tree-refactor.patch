-@interface TabInfo : NSObject {
+// A node in the tab tree: either a tab or (later) a collapsible folder of tabs.
+// Folders are not created yet — every node is currently a tab — but the fields
+// exist so the folder feature can be added without reworking this model.
+typedef NS_ENUM(NSInteger, TabNodeKind) {
+  TabNodeKindTab = 0,
+  TabNodeKindFolder = 1,
+};
