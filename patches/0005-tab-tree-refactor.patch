+@interface TabNode : NSObject {
  @public
+  TabNodeKind kind;               // Tab vs. folder.
+  // Tab payload (kind == TabNodeKindTab):
   raw_ptr<content::Shell> shell;  // Not owned; the Shell is self-owning.
   __weak NSView* webView;         // Owned by the WebContents / view hierarchy.
+  // Folder payload (kind == TabNodeKindFolder):
+  NSMutableArray<TabNode*>* children;
+  BOOL expanded;
+  NSString* folderTitle;
+  // Shared row UI (both kinds):
   NSView* rowView;                // The sidebar row container (owned by strip).
   NSButton* titleButton;
   NSButton* closeButton;
+  __weak TabNode* parent;         // nil = top level.
 }
 @end
 
