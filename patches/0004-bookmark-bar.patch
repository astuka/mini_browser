+// Rebuilds the bookmark buttons (left side of the bar) from the persisted store,
+// keeping the "+" add button. Each button loads its URL in the active tab.
+- (void)rebuildBookmarkBar {
+  if (!_bookmarkBar)
+    return;
+  for (NSView* v in [_bookmarkBar.subviews copy]) {
+    if (v != _addBookmarkButton)
+      [v removeFromSuperview];
+  }
+  [_bookmarkURLs removeAllObjects];
+
+  base::DictValue bookmarks =
+      content::ShellContentBrowserClient::Get()->GetBookmarks();
+  const base::ListValue* roots = bookmarks.FindList("roots");
+  if (!roots)
+    return;
+
+  CGFloat x = 4;
+  int idx = 0;
+  for (const base::Value& item : *roots) {
+    const base::DictValue* d = item.GetIfDict();
+    if (!d)
+      continue;
+    const std::string* type = d->FindString("type");
+    if (type && *type != "bookmark")
+      continue;  // Folders aren't rendered yet.
+    const std::string* url = d->FindString("url");
+    if (!url || url->empty())
+      continue;
+    const std::string* title = d->FindString("title");
+    NSString* label = base::SysUTF8ToNSString(
+        (title && !title->empty()) ? *title : *url);
+
+    NSButton* button = [[NSButton alloc]
+        initWithFrame:NSMakeRect(x, 0, 10, kBookmarkBarHeight)];
+    button.title = label;
+    button.bordered = NO;
+    button.cell.lineBreakMode = NSLineBreakByTruncatingTail;
+    button.target = self;
+    button.action = @selector(bookmarkClicked:);
+    button.tag = idx;
+    [button sizeToFit];
+    NSRect f = button.frame;
+    f.origin.x = x;
+    f.origin.y = 0;
+    f.size.height = kBookmarkBarHeight;
+    f.size.width = std::min(NSWidth(f), CGFloat{160});
+    button.frame = f;
+    [_bookmarkBar addSubview:button];
+    [_bookmarkURLs addObject:base::SysUTF8ToNSString(*url)];
+
+    x += NSWidth(f) + 4;
+    idx++;
+  }
+}
+
+- (void)bookmarkClicked:(id)sender {
+  NSInteger idx = [sender tag];
+  if (idx < 0 || idx >= static_cast<NSInteger>(_bookmarkURLs.count))
+    return;
+  content::Shell* shell = [self activeShell];
+  if (!shell)
+    return;
+  shell->LoadURL(GURL(base::SysNSStringToUTF8(_bookmarkURLs[idx])));
+}
+
+- (void)addCurrentPageBookmark:(id)sender {
+  content::Shell* shell = [self activeShell];
+  if (!shell)
+    return;
+  GURL url = shell->web_contents()->GetLastCommittedURL();
+  if (url.is_empty())
+    return;
+  std::string title = base::UTF16ToUTF8(shell->web_contents()->GetTitle());
+
+  content::ShellContentBrowserClient* client =
+      content::ShellContentBrowserClient::Get();
+  base::DictValue bookmarks = client->GetBookmarks();
+  if (!bookmarks.contains("version"))
+    bookmarks.Set("version", 1);
+  base::ListValue* roots = bookmarks.EnsureList("roots");
+  base::DictValue entry;
+  entry.Set("type", "bookmark");
+  entry.Set("title", title);
+  entry.Set("url", url.spec());
+  roots->Append(std::move(entry));
+  client->SetBookmarks(std::move(bookmarks));
+
+  [self rebuildBookmarkBar];
+}
