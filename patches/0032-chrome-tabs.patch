+void ShellExtensionApiImpl::TabsQuery(const std::string& query_json,
+                                      TabsQueryCallback callback) {
+  std::optional<base::Value> query =
+      base::JSONReader::Read(query_json, base::JSON_PARSE_RFC);
+  std::optional<bool> want_active;
+  if (query && query->is_dict()) {
+    want_active = query->GetDict().FindBool("active");
+  }
+
+  base::ListValue tabs;
+#if BUILDFLAG(IS_MAC)
+  int index = 0;
+  for (const ShellTabInfo& tab : ShellGetTabs()) {
+    if (!want_active.has_value() || *want_active == tab.active) {
+      tabs.Append(TabInfoToValue(tab, index));
+    }
+    ++index;
+  }
+#endif
+  std::string json;
+  base::JSONWriter::Write(tabs, &json);
+  std::move(callback).Run(json);
+}
+
+void ShellExtensionApiImpl::TabsGet(int32_t tab_id, TabsGetCallback callback) {
+#if BUILDFLAG(IS_MAC)
+  int index = 0;
+  for (const ShellTabInfo& tab : ShellGetTabs()) {
+    if (tab.id == tab_id) {
+      std::move(callback).Run(TabInfoToJson(tab, index));
+      return;
+    }
+    ++index;
+  }
+#endif
+  std::move(callback).Run("null");
+}
+
+void ShellExtensionApiImpl::TabsCreate(const std::string& create_json,
+                                       TabsCreateCallback callback) {
+  std::string url;
+  std::optional<base::Value> props =
+      base::JSONReader::Read(create_json, base::JSON_PARSE_RFC);
+  if (props && props->is_dict()) {
+    if (const std::string* u = props->GetDict().FindString("url")) {
+      url = *u;
+    }
+  }
+#if BUILDFLAG(IS_MAC)
+  int new_id = ShellCreateTab(url);
+  // Report the newly created tab back to the caller.
+  int index = 0;
+  for (const ShellTabInfo& tab : ShellGetTabs()) {
+    if (tab.id == new_id) {
+      std::move(callback).Run(TabInfoToJson(tab, index));
+      return;
+    }
+    ++index;
+  }
+#endif
+  std::move(callback).Run("null");
+}
+
+void ShellExtensionApiImpl::TabsUpdate(int32_t tab_id,
+                                       const std::string& update_json,
+                                       TabsUpdateCallback callback) {
+  std::string url;
+  bool make_active = false;
+  std::optional<base::Value> props =
+      base::JSONReader::Read(update_json, base::JSON_PARSE_RFC);
+  if (props && props->is_dict()) {
+    const base::DictValue& dict = props->GetDict();
+    if (const std::string* u = dict.FindString("url")) {
+      url = *u;
+    }
+    make_active = dict.FindBool("active").value_or(false);
+  }
+#if BUILDFLAG(IS_MAC)
+  if (ShellUpdateTab(tab_id, url, make_active)) {
+    // Resolve the (possibly active-tab) target to report it back.
+    int index = 0;
+    for (const ShellTabInfo& tab : ShellGetTabs()) {
+      if ((tab_id < 0 && tab.active) || tab.id == tab_id) {
+        std::move(callback).Run(TabInfoToJson(tab, index));
+        return;
+      }
+      ++index;
+    }
+  }
+#endif
+  std::move(callback).Run("null");
+}
+
 }  // namespace content
