+// Recursively appends tab-kind nodes (in display order) to `out` as ShellTabInfo.
+- (void)collectExtensionTabs:(NSArray<TabNode*>*)nodes
+                        into:(std::vector<content::ShellTabInfo>*)out {
+  for (TabNode* node in nodes) {
+    if (node->kind == TabNodeKindFolder) {
+      [self collectExtensionTabs:node->children into:out];
+      continue;
+    }
+    if (!node->shell) {
+      continue;
+    }
+    content::ShellTabInfo info;
+    info.id = node->tabId;
+    info.url = node->shell->web_contents()->GetLastCommittedURL().spec();
+    info.title = base::UTF16ToUTF8(node->shell->web_contents()->GetTitle());
+    info.active = (node == _activeTab);
+    out->push_back(std::move(info));
+  }
+}
+
+- (std::vector<content::ShellTabInfo>)extensionTabs {
+  std::vector<content::ShellTabInfo> tabs;
+  [self collectExtensionTabs:_tabs into:&tabs];
+  return tabs;
+}
+
+- (TabNode*)tabNodeForId:(int)tabId in:(NSArray<TabNode*>*)nodes {
+  for (TabNode* node in nodes) {
+    if (node->kind == TabNodeKindFolder) {
+      TabNode* found = [self tabNodeForId:tabId in:node->children];
+      if (found) {
+        return found;
+      }
+    } else if (node->tabId == tabId) {
+      return node;
+    }
+  }
+  return nil;
+}
+
+- (int)extensionCreateTabWithURL:(const std::string&)url {
+  content::Shell* active = [self activeShell];
+  if (!active) {
+    return -1;
+  }
+  GURL gurl(url.empty() ? "about:blank" : url);
+  _foregroundNextTab = YES;
+  content::Shell* shell = content::Shell::CreateNewWindow(
+      active->web_contents()->GetBrowserContext(), gurl, nullptr,
+      content::Shell::GetShellDefaultSize());
+  TabNode* node = shell ? [self tabForShell:shell] : nil;
+  return node ? node->tabId : -1;
+}
+
+- (BOOL)extensionUpdateTab:(int)tabId
+                       url:(const std::string&)url
+                makeActive:(BOOL)makeActive {
+  TabNode* node = tabId < 0 ? _activeTab : [self tabNodeForId:tabId in:_tabs];
+  if (!node || node->kind != TabNodeKindTab || !node->shell) {
+    return NO;
+  }
+  if (!url.empty()) {
+    node->shell->LoadURL(GURL(url));
+  }
+  if (makeActive) {
+    [self activateTab:node];
+  }
+  return YES;
+}
