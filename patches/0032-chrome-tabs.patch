+// chrome.tabs bridge (Wield W2): thin C++ wrappers over the tab controller so
+// the browser-side ExtensionApi can answer tabs.query/get/create/update.
+std::vector<ShellTabInfo> ShellGetTabs() {
+  if (!g_tab_controller) {
+    return {};
+  }
+  return [g_tab_controller extensionTabs];
+}
+
+int ShellCreateTab(const std::string& url) {
+  if (!g_tab_controller) {
+    return -1;
+  }
+  return [g_tab_controller extensionCreateTabWithURL:url];
+}
+
+bool ShellUpdateTab(int tab_id, const std::string& url, bool make_active) {
+  if (!g_tab_controller) {
+    return false;
+  }
+  return [g_tab_controller extensionUpdateTab:tab_id
+                                          url:url
+                                   makeActive:make_active];
+}
