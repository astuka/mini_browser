+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CONTENT_SHELL_BROWSER_SHELL_EXTENSION_TABS_H_
+#define CONTENT_SHELL_BROWSER_SHELL_EXTENSION_TABS_H_
+
+#include <string>
+#include <vector>
+
+namespace content {
+
+// A snapshot of one open tab, for the `chrome.tabs` API (Wield epic, W2). Built
+// from the tabbed UI's tab model (the mac TabbedShellController) so the
+// browser-side ExtensionApi can answer tabs.query/get and report created/updated
+// tabs without depending on platform UI types.
+struct ShellTabInfo {
+  int id = 0;
+  std::string url;
+  std::string title;
+  bool active = false;
+};
+
+// Returns all open tabs in display order (folders flattened). Implemented in the
+// platform delegate; returns empty if there's no tab controller.
+std::vector<ShellTabInfo> ShellGetTabs();
+
+// Opens a new tab loading `url` (blank if empty) and returns its tab id, or -1
+// on failure.
+int ShellCreateTab(const std::string& url);
+
+// Navigates tab `tab_id` to `url` (if non-empty) and/or activates it. Returns
+// false if no such tab. `tab_id` < 0 targets the active tab.
+bool ShellUpdateTab(int tab_id, const std::string& url, bool make_active);
+
+}  // namespace content
+
+#endif  // CONTENT_SHELL_BROWSER_SHELL_EXTENSION_TABS_H_
