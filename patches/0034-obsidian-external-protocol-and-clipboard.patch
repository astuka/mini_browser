 #include "content/shell/browser/shell_content_browser_client.h"
 #include "components/crx_file/crx_verifier.h"
 #include "crypto/sha2.h"
@@ -3482,6 +3483,15 @@ bool ShellUpdateTab(int tab_id, const std::string& url, bool make_active) {
   return [g_tab_controller extensionWebContentsForTab:tab_id];
 }
 
+bool ShellLaunchExternalURL(const GURL& url) {
+  NSURL* ns_url = [NSURL URLWithString:base::SysUTF8ToNSString(url.spec())];
+  if (!ns_url) {
+    return false;
+  }
+  [[NSWorkspace sharedWorkspace] openURL:ns_url];
+  return true;
+}
