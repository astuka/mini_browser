     [content addSubview:_bookmarkBar];
 
     // A "+" button pinned to the right of the bar bookmarks the active page.
@@ -1309,6 +1326,55 @@ - (void)dragSessionEnded {
   _draggingNode = nil;
   if (prev)
     [self restyleRow:prev];
+  [self setBookmarkBarHighlighted:NO];
+}
+
+// A tab dragged over the bookmark bar can be dropped to bookmark it (Copy). A
+// folder being dragged isn't (it has no single URL).
+- (NSDragOperation)bookmarkBarDragEntered {
+  if (!_draggingNode || _draggingNode->kind != TabNodeKindTab)
+    return NSDragOperationNone;
+  [self setBookmarkBarHighlighted:YES];
+  return NSDragOperationCopy;
+}
+
+- (void)bookmarkBarDragExited {
+  [self setBookmarkBarHighlighted:NO];
+}
+
+- (void)setBookmarkBarHighlighted:(BOOL)on {
+  if (!_bookmarkBar.wantsLayer)
+    return;
+  _bookmarkBar.layer.backgroundColor =
+      on ? [NSColor.controlAccentColor colorWithAlphaComponent:0.30].CGColor
+         : NSColor.clearColor.CGColor;
+}
+
+- (BOOL)performBookmarkBarDrop {
+  TabNode* tab = _draggingNode;
+  [self setBookmarkBarHighlighted:NO];
+  if (!tab || tab->kind != TabNodeKindTab || !tab->shell)
+    return NO;
+  GURL url = tab->shell->web_contents()->GetLastCommittedURL();
+  if (url.is_empty())
+    return NO;
+  std::string title = base::UTF16ToUTF8(tab->shell->web_contents()->GetTitle());
+
+  content::ShellContentBrowserClient* client =
+      content::ShellContentBrowserClient::Get();
+  base::DictValue bookmarks = client->GetBookmarks();
+  if (!bookmarks.contains("version"))
+    bookmarks.Set("version", 1);
+  base::ListValue* roots = bookmarks.EnsureList("roots");
+  base::DictValue entry;
+  entry.Set("type", "bookmark");
+  entry.Set("title", title);
+  entry.Set("url", url.spec());
+  roots->Append(std::move(entry));
+  client->SetBookmarks(std::move(bookmarks));
+
+  [self rebuildBookmarkBar];
+  return YES;
 }
 
