@@ -283,11 +295,16 @@ - (instancetype)initWithContentSize:(NSSize)size {
     _urlField.cell.scrollable = YES;
     [content addSubview:_urlField];
 
-    // Horizontal bookmark bar, between the toolbar and the content area.
