+
+#ifndef CONTENT_SHELL_BROWSER_SHELL_EXTENSION_SCRIPTS_IMPL_H_
+#define CONTENT_SHELL_BROWSER_SHELL_EXTENSION_SCRIPTS_IMPL_H_
+
+#include "content/shell/common/shell_extension_scripts.mojom.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+
+namespace content {
+
+class RenderFrameHost;
+
+// Browser-side provider of installed extensions' content scripts (Graft epic,
+// E3). The renderer queries this once per frame; we read each enabled
+// extension's manifest + JS files from disk and hand back the scripts so the
+// renderer can match URLs and inject them into isolated worlds.
+class ShellExtensionScriptsImpl : public mojom::ShellExtensionScripts {
+ public:
+  // Binder for ShellContentBrowserClient::RegisterBrowserInterfaceBindersForFrame.
+  static void Create(
+      RenderFrameHost* render_frame_host,
+      mojo::PendingReceiver<mojom::ShellExtensionScripts> receiver);
+
+  ShellExtensionScriptsImpl();
+  ~ShellExtensionScriptsImpl() override;
+
+  ShellExtensionScriptsImpl(const ShellExtensionScriptsImpl&) = delete;
+  ShellExtensionScriptsImpl& operator=(const ShellExtensionScriptsImpl&) =
+      delete;
+
+  // mojom::ShellExtensionScripts:
+  void GetContentScripts(GetContentScriptsCallback callback) override;
+};
+
+}  // namespace content
+
+#endif  // CONTENT_SHELL_BROWSER_SHELL_EXTENSION_SCRIPTS_IMPL_H_
