diff --git a/content/shell/browser/shell_extension_scripts_impl.cc b/content/shell/browser/shell_extension_scripts_impl.cc
new file mode 100644
index 0000000000..12d3f3cec1
--- /dev/null
+++ b/content/shell/browser/shell_extension_scripts_impl.cc
@@ -0,0 +1,159 @@
+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/shell/browser/shell_extension_scripts_impl.h"
+
+#include <functional>
+#include <string>
+#include <utility>
+#include <vector>
+
+#include "base/files/file_path.h"
+#include "base/files/file_util.h"
+#include "base/functional/bind.h"
+#include "base/json/json_reader.h"
+#include "base/task/thread_pool.h"
+#include "base/values.h"
+#include "content/shell/browser/shell_content_browser_client.h"
+#include "mojo/public/cpp/bindings/self_owned_receiver.h"
+
+namespace content {
+
+namespace {
+
+// An enabled extension's id + on-disk root, snapshotted on the UI thread before
+// the (blocking) manifest/JS reads happen on a worker thread.
+struct ExtensionSpec {
+  std::string id;
+  std::string path;
+};
+
+mojom::ContentScriptRunAt ParseRunAt(const std::string* run_at) {
+  if (run_at) {
+    if (*run_at == "document_start") {
+      return mojom::ContentScriptRunAt::kDocumentStart;
+    }
+    if (*run_at == "document_end") {
+      return mojom::ContentScriptRunAt::kDocumentEnd;
+    }
+  }
+  // MV3 default.
+  return mojom::ContentScriptRunAt::kDocumentIdle;
+}
+
+void AppendStrings(const base::ListValue* list, std::vector<std::string>* out) {
+  if (!list) {
+    return;
+  }
+  for (const base::Value& v : *list) {
+    if (v.is_string()) {
+      out->push_back(v.GetString());
+    }
+  }
+}
+
+// Reads each extension's manifest + content-script JS from disk. Runs on a
+// MayBlock thread pool task.
+std::vector<mojom::ContentScriptPtr> BuildContentScripts(
+    std::vector<ExtensionSpec> specs) {
+  std::vector<mojom::ContentScriptPtr> result;
+
+  for (const ExtensionSpec& spec : specs) {
+    base::FilePath root = base::FilePath::FromUTF8Unsafe(spec.path);
+    std::string manifest_text;
+    if (!base::ReadFileToString(root.Append("manifest.json"), &manifest_text)) {
+      continue;
+    }
+    std::optional<base::Value> parsed = base::JSONReader::Read(
+        manifest_text, base::JSON_PARSE_CHROMIUM_EXTENSIONS);
+    if (!parsed || !parsed->is_dict()) {
+      continue;
+    }
+    const base::ListValue* content_scripts =
+        parsed->GetDict().FindList("content_scripts");
+    if (!content_scripts) {
+      continue;
+    }
+
+    // A stable isolated world per extension within this renderer.
+    const int32_t world_id =
+        1000 + static_cast<int32_t>(std::hash<std::string>{}(spec.id) % 1000);
+
+    for (const base::Value& entry : *content_scripts) {
+      if (!entry.is_dict()) {
+        continue;
+      }
+      const base::DictValue& cs = entry.GetDict();
+
+      auto script = mojom::ContentScript::New();
+      AppendStrings(cs.FindList("matches"), &script->matches);
+      AppendStrings(cs.FindList("exclude_matches"), &script->exclude_matches);
+      script->run_at = ParseRunAt(cs.FindString("run_at"));
+      script->world_id = world_id;
+
+      if (const base::ListValue* js = cs.FindList("js")) {
+        for (const base::Value& file : *js) {
+          if (!file.is_string()) {
+            continue;
+          }
+          std::string source;
+          if (base::ReadFileToString(
+                  root.Append(base::FilePath::FromUTF8Unsafe(file.GetString())),
+                  &source)) {
+            script->js_sources.push_back(std::move(source));
+          }
+        }
+      }
+
+      if (!script->matches.empty() && !script->js_sources.empty()) {
+        result.push_back(std::move(script));
+      }
+    }
+  }
+
+  return result;
+}
+
+}  // namespace
+
+// static
+void ShellExtensionScriptsImpl::Create(
+    RenderFrameHost* render_frame_host,
+    mojo::PendingReceiver<mojom::ShellExtensionScripts> receiver) {
+  mojo::MakeSelfOwnedReceiver(std::make_unique<ShellExtensionScriptsImpl>(),
+                              std::move(receiver));
+}
+
+ShellExtensionScriptsImpl::ShellExtensionScriptsImpl() = default;
+ShellExtensionScriptsImpl::~ShellExtensionScriptsImpl() = default;
+
+void ShellExtensionScriptsImpl::GetContentScripts(
+    GetContentScriptsCallback callback) {
+  // Snapshot enabled extensions on the UI thread (touches the pref store).
+  base::DictValue extensions =
+      ShellContentBrowserClient::Get()->GetExtensions();
+  std::vector<ExtensionSpec> specs;
+  for (auto&& [id, value] : extensions) {
+    if (!value.is_dict()) {
+      continue;
+    }
+    const base::DictValue& dict = value.GetDict();
+    if (!dict.FindBool("enabled").value_or(true)) {
+      continue;
+    }
+    const std::string* path = dict.FindString("path");
+    if (!path) {
+      continue;
+    }
+    specs.push_back({id, *path});
+  }
+
+  // The manifest + JS reads block, so do them off the UI thread.
+  base::ThreadPool::PostTaskAndReplyWithResult(
+      FROM_HERE, {base::MayBlock(), base::TaskPriority::USER_BLOCKING},
+      base::BindOnce(&BuildContentScripts, std::move(specs)),
+      std::move(callback));
+}
+
+}  // namespace content
