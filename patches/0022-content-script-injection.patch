index 3fb7ab7f91..e9a19cb18f 100644
--- a/content/shell/renderer/shell_render_frame_observer.cc
+++ b/content/shell/renderer/shell_render_frame_observer.cc
@@ -4,18 +4,125 @@
 
 #include "content/shell/renderer/shell_render_frame_observer.h"
 
+#include <string_view>
+#include <utility>
+
 #include "base/command_line.h"
+#include "base/functional/bind.h"
 #include "content/public/renderer/render_frame.h"
 #include "content/public/renderer/render_frame_observer.h"
 #include "content/shell/common/render_frame_test_helper.mojom.h"
 #include "content/shell/common/shell_switches.h"
 #include "content/shell/renderer/render_frame_test_helper.h"
+#include "third_party/blink/public/platform/browser_interface_broker_proxy.h"
+#include "third_party/blink/public/platform/web_string.h"
+#include "third_party/blink/public/web/web_document.h"
+#include "third_party/blink/public/web/web_local_frame.h"
+#include "third_party/blink/public/web/web_script_source.h"
 #include "third_party/blink/public/web/web_testing_support.h"
+#include "url/gurl.h"
 
 namespace content {
 
+namespace {
+
+int RunAtBit(mojom::ContentScriptRunAt run_at) {
+  return 1 << static_cast<int>(run_at);
+}
+
+// Matches `str` against a glob `pattern` where '*' matches any (possibly empty)
+// run of characters. No other metacharacters (Chrome match-pattern paths only
+// use '*').
+bool GlobMatch(std::string_view pattern, std::string_view str) {
+  size_t p = 0, s = 0, star = std::string_view::npos, mark = 0;
+  while (s < str.size()) {
+    if (p < pattern.size() && (pattern[p] == '*')) {
+      star = p++;
+      mark = s;
+    } else if (p < pattern.size() && pattern[p] == str[s]) {
+      ++p;
+      ++s;
+    } else if (star != std::string_view::npos) {
+      p = star + 1;
+      s = ++mark;
+    } else {
+      return false;
+    }
+  }
+  while (p < pattern.size() && pattern[p] == '*') {
+    ++p;
+  }
+  return p == pattern.size();
+}
+
+// Implements a useful subset of Chrome's content-script match patterns:
+// "<all_urls>", "*://*/*", "https://*.example.com/*", etc.
+bool MatchesPattern(const std::string& pattern, const GURL& url) {
+  if (pattern == "<all_urls>") {
+    return url.SchemeIs("http") || url.SchemeIs("https") ||
+           url.SchemeIs("file");
+  }
+
+  size_t scheme_end = pattern.find("://");
+  if (scheme_end == std::string::npos) {
+    return false;
+  }
+  std::string scheme = pattern.substr(0, scheme_end);
+  std::string rest = pattern.substr(scheme_end + 3);
+  size_t path_start = rest.find('/');
+  if (path_start == std::string::npos) {
+    return false;
+  }
+  std::string host = rest.substr(0, path_start);
+  std::string path = rest.substr(path_start);
+
+  // Scheme: '*' means http or https.
+  if (scheme == "*") {
+    if (!url.SchemeIs("http") && !url.SchemeIs("https")) {
+      return false;
+    }
+  } else if (!url.SchemeIs(scheme)) {
+    return false;
+  }
+
+  // Host: '*' (any), "*.suffix" (suffix or subdomain), or an exact host.
+  std::string url_host(url.host());
+  if (host == "*") {
+    // Matches any host.
+  } else if (host.size() > 2 && host[0] == '*' && host[1] == '.') {
+    std::string suffix = host.substr(2);
+    if (url_host != suffix &&
+        !(url_host.size() > suffix.size() &&
+          url_host.ends_with("." + suffix))) {
+      return false;
+    }
+  } else if (url_host != host) {
+    return false;
+  }
+
+  return GlobMatch(path, url.path());
+}
+
+bool ScriptMatchesUrl(const mojom::ContentScript& script, const GURL& url) {
+  for (const std::string& exclude : script.exclude_matches) {
+    if (MatchesPattern(exclude, url)) {
+      return false;
+    }
+  }
+  for (const std::string& match : script.matches) {
+    if (MatchesPattern(match, url)) {
+      return true;
+    }
+  }
+  return false;
+}
+
+}  // namespace
+
 ShellRenderFrameObserver::ShellRenderFrameObserver(RenderFrame* render_frame)
-    : RenderFrameObserver(render_frame) {}
+    : RenderFrameObserver(render_frame) {
+  RequestContentScripts();
+}
 
 ShellRenderFrameObserver::~ShellRenderFrameObserver() = default;
 
@@ -42,4 +149,78 @@ void ShellRenderFrameObserver::OnInterfaceRequestForFrame(
   }
 }
 
+void ShellRenderFrameObserver::DidCommitProvisionalLoad(
+    ui::PageTransition transition) {
+  // A new document: reset which run_at stages have fired.
+  stages_reached_ = 0;
+}
+
+void ShellRenderFrameObserver::DidCreateDocumentElement() {
+  HandleRunAt(mojom::ContentScriptRunAt::kDocumentStart);
+}
+
+void ShellRenderFrameObserver::DidDispatchDOMContentLoadedEvent() {
+  HandleRunAt(mojom::ContentScriptRunAt::kDocumentEnd);
+}
+
+void ShellRenderFrameObserver::DidFinishLoad() {
+  HandleRunAt(mojom::ContentScriptRunAt::kDocumentIdle);
+}
+
+void ShellRenderFrameObserver::RequestContentScripts() {
+  render_frame()->GetBrowserInterfaceBroker().GetInterface(
+      extension_scripts_.BindNewPipeAndPassReceiver());
+  extension_scripts_->GetContentScripts(
+      base::BindOnce(&ShellRenderFrameObserver::OnContentScripts,
+                     weak_factory_.GetWeakPtr()));
+}
+
+void ShellRenderFrameObserver::OnContentScripts(
+    std::vector<mojom::ContentScriptPtr> scripts) {
+  content_scripts_ = std::move(scripts);
+  scripts_loaded_ = true;
+
+  // The scripts may have arrived after some run_at stages already fired for the
+  // current document — inject those now so nothing is missed.
+  for (mojom::ContentScriptRunAt run_at :
+       {mojom::ContentScriptRunAt::kDocumentStart,
+        mojom::ContentScriptRunAt::kDocumentEnd,
+        mojom::ContentScriptRunAt::kDocumentIdle}) {
+    if (stages_reached_ & RunAtBit(run_at)) {
+      InjectForRunAt(run_at);
+    }
+  }
+}
+
+void ShellRenderFrameObserver::HandleRunAt(
+    mojom::ContentScriptRunAt run_at) {
+  stages_reached_ |= RunAtBit(run_at);
+  if (scripts_loaded_) {
+    InjectForRunAt(run_at);
+  }
+}
+
+void ShellRenderFrameObserver::InjectForRunAt(
+    mojom::ContentScriptRunAt run_at) {
+  blink::WebLocalFrame* frame = render_frame()->GetWebFrame();
+  if (!frame) {
+    return;
+  }
+  GURL url = frame->GetDocument().Url();
+  for (const mojom::ContentScriptPtr& script : content_scripts_) {
+    if (script->run_at != run_at) {
+      continue;
+    }
+    if (!ScriptMatchesUrl(*script, url)) {
+      continue;
+    }
+    for (const std::string& source : script->js_sources) {
+      frame->ExecuteScriptInIsolatedWorld(
+          script->world_id,
+          blink::WebScriptSource(blink::WebString::FromUtf8(source)),
+          blink::BackForwardCacheAware::kPossiblyDisallow);
+    }
+  }
+}
+
 }  // namespace content
