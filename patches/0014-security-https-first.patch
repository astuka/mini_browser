+// HTTPS-First fallback: shown when an http->https upgrade failed. Primary (safe)
+// stays back; secondary continues to the plain-http URL.
+- (void)presentHttpFallbackForShell:(content::Shell*)shell
+                                url:(const GURL&)url
+                          onResolve:(void (^)(BOOL proceed))resolve {
+  TabNode* tab = shell ? [self tabForShell:shell] : nil;
+  if (!tab) {
+    if (resolve)
+      resolve(NO);
+    return;
+  }
+  NSString* host = base::SysUTF8ToNSString(url.host());
+  NSString* title = @"This site doesn't support HTTPS";
+  NSString* message = [NSString
+      stringWithFormat:@"%@ couldn't be reached over a secure (HTTPS) "
+                       @"connection. Continuing will load it over unencrypted "
+                       @"HTTP, which others on the network may be able to read.",
+                       host.length ? host : @"This site"];
+  [self presentInterstitialInTab:tab
+                           title:title
+                         message:message
+                          detail:nil
+                     primaryText:@"Back to safety"
+                   secondaryText:@"Continue to HTTP site"
+                       onPrimary:^{
+                         if (resolve)
+                           resolve(NO);
+                       }
+                     onSecondary:^{
+                         if (resolve)
+                           resolve(YES);
+                       }];
+}
