+namespace {
+
+// Hosts the user has chosen to load over plain HTTP. Session-scoped for now; a
+// persistent SiteSettings store arrives in a later security PR.
+std::set<std::string>& HttpAllowlist() {
+  static base::NoDestructor<std::set<std::string>> allowlist;
+  return *allowlist;
+}
+
+// Maps a WebContents to the original http:// URL we upgraded from, so that if
+// the https attempt fails we can offer to fall back to it.
+std::map<WebContents*, GURL>& PendingUpgrades() {
+  static base::NoDestructor<std::map<WebContents*, GURL>> pending;
+  return *pending;
+}
+
+void LoadURLOnWebContents(base::WeakPtr<WebContents> web_contents, GURL url) {
+  if (web_contents) {
+    web_contents->GetController().LoadURL(
+        url, Referrer(), ui::PAGE_TRANSITION_TYPED, std::string());
+  }
+}
+
+bool ShouldSkipUpgrade(const GURL& url) {
+  if (!url.SchemeIs("http"))
+    return true;
+  if (url.host().empty() || url.HostIsIPAddress() || url.host() == "localhost")
+    return true;  // Don't upgrade local/IP hosts (often intentionally http).
+  return HttpAllowlist().count(std::string(url.host())) > 0;
+}
+
+// HTTPS-First mode, built from scratch (no //chrome HttpsUpgrades component):
+// upgrades top-level http navigations to https, and if the https attempt fails
+// offers a one-time "continue to http" interstitial.
+class HttpsUpgradeThrottle : public NavigationThrottle {
+ public:
+  explicit HttpsUpgradeThrottle(NavigationThrottleRegistry& registry)
+      : NavigationThrottle(registry) {}
+  ~HttpsUpgradeThrottle() override = default;
+
+  const char* GetNameForLogging() override { return "HttpsUpgradeThrottle"; }
+
+  ThrottleCheckResult WillStartRequest() override {
+    NavigationHandle* handle = navigation_handle();
+    if (!handle->IsInPrimaryMainFrame())
+      return PROCEED;
+    const GURL& url = handle->GetURL();
+    if (ShouldSkipUpgrade(url))
+      return PROCEED;
+
+    WebContents* web_contents = handle->GetWebContents();
+    PendingUpgrades()[web_contents] = url;  // Remember the original http URL.
+    base::SingleThreadTaskRunner::GetCurrentDefault()->PostTask(
+        FROM_HERE, base::BindOnce(&LoadURLOnWebContents,
+                                  web_contents->GetWeakPtr(), UpgradedURL(url)));
+    return CANCEL_AND_IGNORE;
+  }
+
+  ThrottleCheckResult WillProcessResponse() override {
+    PendingUpgrades().erase(navigation_handle()->GetWebContents());
+    return PROCEED;
+  }
+
+  ThrottleCheckResult WillFailRequest() override {
+    NavigationHandle* handle = navigation_handle();
+    WebContents* web_contents = handle->GetWebContents();
+    auto it = PendingUpgrades().find(web_contents);
+    if (it == PendingUpgrades().end())
+      return PROCEED;
+    GURL original_http = it->second;
+    // Only fall back if this failed request is the upgrade of that http URL.
+    if (handle->GetURL() != UpgradedURL(original_http))
+      return PROCEED;
+    PendingUpgrades().erase(it);
+
+#if BUILDFLAG(IS_MAC)
+    deferred_http_url_ = original_http;
+    ShellPlatformDelegate::RequestHttpFallbackDecision(
+        web_contents, original_http,
+        base::BindOnce(&HttpsUpgradeThrottle::OnFallbackDecision,
+                       weak_factory_.GetWeakPtr()));
+    return DEFER;
+#else
+    return PROCEED;
+#endif
+  }
+
+ private:
+  static GURL UpgradedURL(const GURL& http_url) {
+    GURL::Replacements replace_scheme;
+    replace_scheme.SetSchemeStr("https");
+    return http_url.ReplaceComponents(replace_scheme);
+  }
+
+  void OnFallbackDecision(bool proceed) {
+    if (proceed) {
+      HttpAllowlist().insert(std::string(deferred_http_url_.host()));
+      WebContents* web_contents = navigation_handle()->GetWebContents();
+      base::SingleThreadTaskRunner::GetCurrentDefault()->PostTask(
+          FROM_HERE, base::BindOnce(&LoadURLOnWebContents,
+                                    web_contents->GetWeakPtr(),
+                                    deferred_http_url_));
+    }
+    CancelDeferredNavigation(CANCEL_AND_IGNORE);
+  }
+
+  GURL deferred_http_url_;
+  base::WeakPtrFactory<HttpsUpgradeThrottle> weak_factory_{this};
+};
+
+}  // namespace
+
 void ShellContentBrowserClient::CreateThrottlesForNavigation(
     NavigationThrottleRegistry& registry) {
+  registry.AddThrottle(std::make_unique<HttpsUpgradeThrottle>(registry));
   if (create_throttles_for_navigation_callback_) {
     create_throttles_for_navigation_callback_.Run(registry);
   }
