+// Installs a packaged .crx (E8): verifies the CRX3 signature, unpacks the ZIP to
+// a managed dir under the profile, and registers it under its signature-derived
+// id. Rejects tampered/invalid packages.
+- (void)installCrxFromPath:(NSString*)crxPath {
+  base::ScopedAllowBlockingForTesting allow_blocking;
+  base::FilePath crx(base::SysNSStringToUTF8(crxPath));
+
+  std::string public_key;
+  std::string crx_id;
+  crx_file::VerifierResult result =
+      crx_file::Verify(crx, crx_file::VerifierFormat::CRX3,
+                       /*required_key_hashes=*/{}, /*required_file_hash=*/{},
+                       &public_key, &crx_id, /*compressed_verified_contents=*/
+                       nullptr);
+  if (result != crx_file::VerifierResult::OK_FULL) {
+    [self showExtensionError:
+              [NSString stringWithFormat:
+                            @"CRX signature verification failed (code %d). The "
+                            @"package may be corrupt or tampered with.",
+                            static_cast<int>(result)]];
+    return;
+  }
+
+  // Find where the ZIP archive starts: 12-byte prefix (magic + version +
+  // header_size) followed by the CrxFileHeader, then the ZIP.
+  std::string crx_bytes;
+  if (!base::ReadFileToString(crx, &crx_bytes) || crx_bytes.size() < 12) {
+    [self showExtensionError:@"Couldn't read the CRX file."];
+    return;
+  }
+  uint32_t header_size =
+      static_cast<uint8_t>(crx_bytes[8]) |
+      (static_cast<uint8_t>(crx_bytes[9]) << 8) |
+      (static_cast<uint8_t>(crx_bytes[10]) << 16) |
+      (static_cast<uint32_t>(static_cast<uint8_t>(crx_bytes[11])) << 24);
+  size_t zip_offset = 12u + header_size;
+  if (zip_offset >= crx_bytes.size()) {
+    [self showExtensionError:@"CRX contains no archive."];
+    return;
+  }
+
+  content::Shell* active = [self activeShell];
+  content::BrowserContext* browser_context =
+      active ? active->web_contents()->GetBrowserContext() : nullptr;
+  if (!browser_context)
+    return;
+  base::FilePath dest =
+      browser_context->GetPath().Append("CRXExtensions").Append(crx_id);
+  base::DeletePathRecursively(dest);  // Reinstall cleanly.
+  if (!base::CreateDirectory(dest)) {
+    [self showExtensionError:@"Couldn't create the install directory."];
+    return;
+  }
+
+  // Write the ZIP portion to a temp file and unpack it.
+  base::FilePath temp_zip = dest.DirName().Append(crx_id + ".zip");
+  if (!base::WriteFile(temp_zip,
+                       std::string_view(crx_bytes).substr(zip_offset))) {
+    [self showExtensionError:@"Couldn't stage the CRX archive."];
+    return;
+  }
+  bool unzipped = zip::Unzip(temp_zip, dest);
+  base::DeleteFile(temp_zip);
+  if (!unzipped) {
+    [self showExtensionError:@"Couldn't unpack the CRX archive."];
+    return;
+  }
+
+  if ([self registerExtensionAtPath:base::SysUTF8ToNSString(dest.value())
+                            withId:base::SysUTF8ToNSString(crx_id)]) {
+    [self refreshExtensionSurfaces];
+  }
+}
