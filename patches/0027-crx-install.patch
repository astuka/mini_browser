+- (void)loadPackagedExtension:(id)sender {
+  NSOpenPanel* panel = [NSOpenPanel openPanel];
+  panel.canChooseFiles = YES;
+  panel.canChooseDirectories = NO;
+  panel.allowsMultipleSelection = NO;
+  panel.prompt = @"Install";
+  panel.message = @"Choose a packaged extension (.crx)";
+  NSWindow* host = _extensionsPanel ?: _window;
+  __weak TabbedShellController* weakSelf = self;
+  void (^handler)(NSModalResponse) = ^(NSModalResponse modalResult) {
+    if (modalResult != NSModalResponseOK || panel.URLs.count == 0)
+      return;
+    [weakSelf installCrxFromPath:panel.URLs.firstObject.path];
+  };
+  if (host)
+    [panel beginSheetModalForWindow:host completionHandler:handler];
+  else
+    handler([panel runModal]);
+}
