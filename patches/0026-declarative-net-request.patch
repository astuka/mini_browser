+void ShellContentBrowserClient::ReloadExtensionNetRules() {
+  // Recompiles the declarativeNetRequest block filters from enabled extensions'
+  // static rule resources. UI thread; small, infrequent (startup + on extension
+  // change), so the file reads are done synchronously.
+  base::ScopedAllowBlockingForTesting allow_blocking;
+  std::vector<std::string> filters;
+
+  base::DictValue extensions = GetExtensions();
+  for (auto&& [id, value] : extensions) {
+    if (!value.is_dict()) {
+      continue;
+    }
+    const base::DictValue& entry = value.GetDict();
+    if (!entry.FindBool("enabled").value_or(true)) {
+      continue;
+    }
+    const std::string* path = entry.FindString("path");
+    if (!path) {
+      continue;
+    }
+    base::FilePath root = base::FilePath::FromUTF8Unsafe(*path);
+
+    std::string manifest_text;
+    if (!base::ReadFileToString(root.Append("manifest.json"), &manifest_text)) {
+      continue;
+    }
+    std::optional<base::Value> manifest = base::JSONReader::Read(
+        manifest_text, base::JSON_PARSE_CHROMIUM_EXTENSIONS);
+    if (!manifest || !manifest->is_dict()) {
+      continue;
+    }
+    const base::DictValue* dnr =
+        manifest->GetDict().FindDict("declarative_net_request");
+    const base::ListValue* resources =
+        dnr ? dnr->FindList("rule_resources") : nullptr;
+    if (!resources) {
+      continue;
+    }
+
+    for (const base::Value& resource : *resources) {
+      if (!resource.is_dict()) {
+        continue;
+      }
+      const base::DictValue& res = resource.GetDict();
+      if (!res.FindBool("enabled").value_or(true)) {
+        continue;
+      }
+      const std::string* rule_path = res.FindString("path");
+      if (!rule_path) {
+        continue;
+      }
+      std::string rules_text;
+      if (!base::ReadFileToString(
+              root.Append(base::FilePath::FromUTF8Unsafe(*rule_path)),
+              &rules_text)) {
+        continue;
+      }
+      std::optional<base::Value> rules = base::JSONReader::Read(
+          rules_text, base::JSON_PARSE_CHROMIUM_EXTENSIONS);
+      if (!rules || !rules->is_list()) {
+        continue;
+      }
+      for (const base::Value& rule : rules->GetList()) {
+        if (!rule.is_dict()) {
+          continue;
+        }
+        const base::DictValue& r = rule.GetDict();
+        const base::DictValue* action = r.FindDict("action");
+        const std::string* type = action ? action->FindString("type") : nullptr;
+        if (!type || *type != "block") {
+          continue;  // E7 supports `block` rules only.
+        }
+        const base::DictValue* condition = r.FindDict("condition");
+        const std::string* url_filter =
+            condition ? condition->FindString("urlFilter") : nullptr;
+        if (url_filter && !url_filter->empty()) {
+          filters.push_back(*url_filter);
+        }
+      }
+    }
+  }
+
+  ExtensionNetRules() = std::move(filters);
+}
