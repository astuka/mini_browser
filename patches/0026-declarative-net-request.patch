+    scoped_refptr<base::SequencedTaskRunner> navigation_response_task_runner) {
+  // Insert the declarativeNetRequest blocking proxy (Graft E7) in front of the
+  // real factory so it sees subresource requests too. Skipped entirely when no
+  // extension declares block rules.
+  if (ExtensionNetRules().empty()) {
+    return;
+  }
+  auto [receiver, remote] = factory_builder.Append();
+  DNRProxyFactory::CreateAndStart(std::move(receiver), std::move(remote),
+                                  ExtensionNetRules());
+}
