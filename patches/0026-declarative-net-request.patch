+// --- declarativeNetRequest (Graft epic, E7) -------------------------------
+//
+// Block-rule URL filters compiled from enabled extensions' static DNR rule
+// resources. Mutated and read only on the UI thread (in ReloadExtensionNetRules
+// and CreateURLLoaderThrottles); each throttle gets its own immutable copy, so
+// matching on the loader sequence is race-free.
+std::vector<std::string>& ExtensionNetRules() {
+  static base::NoDestructor<std::vector<std::string>> rules;
+  return *rules;
+}
+
+// Matches a DNR `urlFilter` against a URL. Implements a pragmatic subset: `*`
+// wildcards, `^` treated as a wildcard separator, and `|`/`||` anchors stripped
+// (domain-anchored rules are approximated as ordered substrings). Case-
+// insensitive, matching Chrome's default.
+bool MatchesUrlFilter(std::string filter, std::string url) {
+  filter = base::ToLowerASCII(filter);
+  url = base::ToLowerASCII(url);
+  if (filter.starts_with("||")) {
+    filter = filter.substr(2);
+  } else if (filter.starts_with("|")) {
+    filter = filter.substr(1);
+  }
+  if (filter.ends_with("|")) {
+    filter.pop_back();
+  }
+  base::ReplaceChars(filter, "^", "*", &filter);
+
+  // Each non-empty segment between '*' must appear in order in the URL.
+  size_t pos = 0;
+  for (std::string_view segment : base::SplitStringPiece(
+           filter, "*", base::KEEP_WHITESPACE, base::SPLIT_WANT_ALL)) {
+    if (segment.empty()) {
+      continue;
+    }
+    size_t found = url.find(segment, pos);
+    if (found == std::string::npos) {
+      return false;
+    }
+    pos = found + segment.size();
+  }
+  return true;
+}
+
+// A proxying URLLoaderFactory inserted (via WillCreateURLLoaderFactory) in front
+// of the real factory the renderer uses. It cancels requests matching any
+// enabled extension's DNR block rule — the core of an ad/content blocker — and
+// forwards everything else to the target factory. Unlike a browser-side
+// URLLoaderThrottle (navigation-only), this catches subresource requests too.
+class DNRProxyFactory : public network::SelfDeletingURLLoaderFactory {
+ public:
+  static void CreateAndStart(
+      mojo::PendingReceiver<network::mojom::URLLoaderFactory> receiver,
+      mojo::PendingRemote<network::mojom::URLLoaderFactory> target,
+      std::vector<std::string> filters) {
+    // Owns its own lifetime (self-deletes when all receivers disconnect).
+    new DNRProxyFactory(std::move(receiver), std::move(target),
+                        std::move(filters));
+  }
+
+  DNRProxyFactory(const DNRProxyFactory&) = delete;
+  DNRProxyFactory& operator=(const DNRProxyFactory&) = delete;
+
+  void CreateLoaderAndStart(
+      mojo::PendingReceiver<network::mojom::URLLoader> loader,
+      int32_t request_id,
+      uint32_t options,
+      const network::ResourceRequest& request,
+      mojo::PendingRemote<network::mojom::URLLoaderClient> client,
+      const net::MutableNetworkTrafficAnnotationTag& traffic_annotation)
+      override {
+    std::string url = request.url.spec();
+    for (const std::string& filter : filters_) {
+      if (MatchesUrlFilter(filter, url)) {
+        mojo::Remote<network::mojom::URLLoaderClient> client_remote(
+            std::move(client));
+        client_remote->OnComplete(
+            network::URLLoaderCompletionStatus(net::ERR_BLOCKED_BY_CLIENT));
+        return;
+      }
+    }
+    target_->CreateLoaderAndStart(std::move(loader), request_id, options,
+                                  request, std::move(client),
+                                  traffic_annotation);
+  }
+
+ private:
+  DNRProxyFactory(
+      mojo::PendingReceiver<network::mojom::URLLoaderFactory> receiver,
+      mojo::PendingRemote<network::mojom::URLLoaderFactory> target,
+      std::vector<std::string> filters)
+      : network::SelfDeletingURLLoaderFactory(std::move(receiver)),
+        target_(std::move(target)),
+        filters_(std::move(filters)) {}
+
+  mojo::Remote<network::mojom::URLLoaderFactory> target_;
+  std::vector<std::string> filters_;
+};
+
