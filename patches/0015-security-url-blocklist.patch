+// static
+void ShellPlatformDelegate::RequestBlocklistDecision(
+    WebContents* web_contents,
+    const GURL& url,
+    base::OnceCallback<void(bool)> callback) {
+  __block base::OnceCallback<void(bool)> cb = std::move(callback);
+  void (^resolve)(BOOL) = ^(BOOL proceed) {
+    if (cb)
+      std::move(cb).Run(proceed);
+  };
+  Shell* shell = Shell::FromWebContents(web_contents);
+  if (!shell || !g_tab_controller) {
+    resolve(NO);
+    return;
+  }
+  [g_tab_controller presentBlocklistForShell:shell url:url onResolve:resolve];
+}
