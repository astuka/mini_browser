+// Blocklist ("dangerous site") interstitial. Primary (safe) goes back; secondary
+// visits the site anyway.
+- (void)presentBlocklistForShell:(content::Shell*)shell
+                             url:(const GURL&)url
+                       onResolve:(void (^)(BOOL proceed))resolve {
+  TabNode* tab = shell ? [self tabForShell:shell] : nil;
+  if (!tab) {
+    if (resolve)
+      resolve(NO);
+    return;
+  }
+  NSString* host = base::SysUTF8ToNSString(url.host());
+  NSString* title = @"Dangerous site blocked";
+  NSString* message = [NSString
+      stringWithFormat:@"%@ is on this browser's blocklist of sites known for "
+                       @"malware or phishing. Visiting it could put your device "
+                       @"or information at risk.",
+                       host.length ? host : @"This site"];
+  [self presentInterstitialInTab:tab
+                           title:title
+                         message:message
+                          detail:nil
+                     primaryText:@"Back to safety"
+                   secondaryText:@"Visit anyway (dangerous)"
+                       onPrimary:^{
+                         if (resolve)
+                           resolve(NO);
+                       }
+                     onSecondary:^{
+                         if (resolve)
+                           resolve(YES);
+                       }];
+}
