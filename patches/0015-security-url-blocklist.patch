+// A local URL-reputation blocklist — our own miniature "Safe Browsing." A real
+// deployment would load a hosts-style list (e.g. StevenBlack); here we ship a
+// small built-in seed. Lookups are O(1) host-string matches done before the
+// network request, so a blocked host needn't even resolve.
+const base::flat_set<std::string_view>& Blocklist() {
+  static const base::NoDestructor<base::flat_set<std::string_view>> list({
+      "testsafebrowsing.appspot.com",  // Google's real Safe Browsing test host.
+      "malware.testing.google.test",
+      "malware.example",
+      "phishing.example",
+  });
+  return *list;
+}
+
+// Hosts the user chose to visit anyway this session.
+std::set<std::string>& BlocklistAllowlist() {
+  static base::NoDestructor<std::set<std::string>> allowlist;
+  return *allowlist;
+}
+
+// Blocks navigations to known-bad hosts with a warning interstitial. Built from
+// scratch (no Google Safe Browsing).
+class BlocklistThrottle : public NavigationThrottle {
+ public:
+  explicit BlocklistThrottle(NavigationThrottleRegistry& registry)
+      : NavigationThrottle(registry) {}
+  ~BlocklistThrottle() override = default;
+
+  const char* GetNameForLogging() override { return "BlocklistThrottle"; }
+
+  ThrottleCheckResult WillStartRequest() override {
+    NavigationHandle* handle = navigation_handle();
+    if (!handle->IsInPrimaryMainFrame())
+      return PROCEED;
+    std::string host(handle->GetURL().host());
+    if (!Blocklist().contains(host) || BlocklistAllowlist().count(host) > 0)
+      return PROCEED;
+
+    blocked_host_ = host;
+#if BUILDFLAG(IS_MAC)
+    ShellPlatformDelegate::RequestBlocklistDecision(
+        handle->GetWebContents(), handle->GetURL(),
+        base::BindOnce(&BlocklistThrottle::OnDecision,
+                       weak_factory_.GetWeakPtr()));
+    return DEFER;
+#else
+    return CANCEL_AND_IGNORE;
+#endif
+  }
+
+ private:
+  void OnDecision(bool proceed) {
+    if (proceed) {
+      BlocklistAllowlist().insert(blocked_host_);
+      Resume();  // Continue the deferred navigation to the (risky) site.
+    } else {
+      CancelDeferredNavigation(CANCEL_AND_IGNORE);
+    }
+  }
+
+  std::string blocked_host_;
+  base::WeakPtrFactory<BlocklistThrottle> weak_factory_{this};
+};
+
 }  // namespace
 
