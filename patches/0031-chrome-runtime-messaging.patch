+#include "content/shell/renderer/shell_extension_context_bindings.h"
+
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/strings/string_util.h"
+#include "content/public/renderer/render_frame.h"
+#include "gin/arguments.h"
+#include "gin/converter.h"
+#include "gin/function_template.h"
+#include "third_party/blink/public/platform/browser_interface_broker_proxy.h"
+#include "v8/include/v8.h"
+
+namespace content {
+
+namespace {
+
+// The `chrome.*` shim, returned as a function expression that takes the native
+// bridge object `__api` so the bridge never lands on a page's global. The caller
+// runs it and invokes it with that object.
+//
+// runtime.id/getURL are trivial JS; `chrome.storage.local` and
+// `chrome.runtime` messaging are backed by `__api` (browser-routed), so an
+// extension's data and messages flow through one browser-side path shared by all
+// of its contexts (pages and content scripts). `__EXTENSION_ID__` is substituted
+// before injection.
+std::string BuildChromeShim(const std::string& extension_id) {
+  static const char kShim[] = R"JS(
+(function(__api) {
+  if (window.chrome && window.chrome.runtime && window.chrome.runtime.id) {
+    return;
+  }
+  var EXT_ID = "__EXTENSION_ID__";
+  var chrome = window.chrome || {};
+
+  chrome.runtime = chrome.runtime || {};
+  chrome.runtime.id = EXT_ID;
+  chrome.runtime.getURL = function(path) {
+    return "chrome-extension://" + EXT_ID + "/" +
+           String(path == null ? "" : path).replace(/^\//, "");
+  };
+
+  // Browser-routed chrome.runtime messaging (Wield W1c). sendMessage hands the
+  // message to the browser, which fans it out to this extension's other
+  // contexts; incoming messages arrive via the dispatcher registered below.
+  var listeners = [];
+  chrome.runtime.onMessage = {
+    addListener: function(fn) { if (typeof fn === "function") listeners.push(fn); },
+    removeListener: function(fn) {
+      var i = listeners.indexOf(fn);
+      if (i >= 0) listeners.splice(i, 1);
+    }
+  };
+  chrome.runtime.sendMessage = function(message, cb) {
+    if (typeof message === "function") { cb = message; message = undefined; }
+    var json;
+    try { json = JSON.stringify(message === undefined ? null : message); }
+    catch (e) { json = "null"; }
+    __api.sendMessage(json);
+    if (typeof cb === "function") { setTimeout(function() { cb(); }, 0); }
+    return Promise.resolve();
+  };
+  __api.setMessageDispatcher(function(messageJson, senderJson) {
+    var message, sender;
+    try { message = JSON.parse(messageJson); } catch (e) { message = null; }
+    try { sender = JSON.parse(senderJson); } catch (e) { sender = {}; }
+    listeners.slice().forEach(function(fn) {
+      try { fn(message, sender, function() {}); } catch (_) {}
+    });
+  });
+
+  // Browser-backed chrome.storage.local (Wield W1a). The native bridge stores
+  // and returns the extension's whole blob as JSON; the get(keys)/defaults
+  // semantics stay here in JS.
+  chrome.storage = chrome.storage || {};
+  var changeListeners = [];
+  function fireChanges(changes) {
+    if (!changeListeners.length) return;
+    changeListeners.slice().forEach(function(fn) {
+      try { fn(changes, "local"); } catch (_) {}
+    });
+  }
+  chrome.storage.local = {
+    get: function(keys, cb) {
+      if (typeof keys === "function" && cb === undefined) {
+        cb = keys; keys = null;
+      }
+      var p = __api.storageGet(EXT_ID).then(function(jsonStr) {
+        var all;
+        try { all = JSON.parse(jsonStr) || {}; } catch (e) { all = {}; }
+        var result = {};
+        if (keys == null) {
+          result = all;
+        } else if (typeof keys === "string") {
+          if (keys in all) result[keys] = all[keys];
+        } else if (Array.isArray(keys)) {
+          keys.forEach(function(k) { if (k in all) result[k] = all[k]; });
+        } else if (typeof keys === "object") {
+          Object.keys(keys).forEach(function(k) {
+            result[k] = (k in all) ? all[k] : keys[k];
+          });
+        }
+        if (typeof cb === "function") cb(result);
+        return result;
+      });
+      return p;
+    },
+    set: function(items, cb) {
+      items = items || {};
+      var p = __api.storageSet(EXT_ID, JSON.stringify(items)).then(function() {
+        var changes = {};
+        Object.keys(items).forEach(function(k) {
+          changes[k] = { newValue: items[k] };
+        });
+        fireChanges(changes);
+        if (typeof cb === "function") cb();
+      });
+      return p;
+    },
+    remove: function(keys, cb) {
+      var arr = Array.isArray(keys) ? keys : [keys];
+      var p = __api.storageRemove(EXT_ID, JSON.stringify(arr)).then(function() {
+        var changes = {};
+        arr.forEach(function(k) { changes[k] = {}; });
+        fireChanges(changes);
+        if (typeof cb === "function") cb();
+      });
+      return p;
+    },
+    clear: function(cb) {
+      var p = __api.storageClear(EXT_ID).then(function() {
+        if (typeof cb === "function") cb();
+      });
+      return p;
+    }
+  };
+  // Many extensions use chrome.storage.sync; back it with the same local store.
+  chrome.storage.sync = chrome.storage.local;
+  chrome.storage.onChanged = {
+    addListener: function(fn) {
+      if (typeof fn === "function") changeListeners.push(fn);
+    },
+    removeListener: function(fn) {
+      var i = changeListeners.indexOf(fn);
+      if (i >= 0) changeListeners.splice(i, 1);
+    }
+  };
+
+  // Minimal chrome.action stubs (full support arrives later in the epic).
+  chrome.action = chrome.action || {
+    setBadgeText: function(_d, cb) { if (typeof cb === "function") cb(); },
+    setTitle: function(_d, cb) { if (typeof cb === "function") cb(); },
+    onClicked: { addListener: function() {} }
+  };
+
+  window.chrome = chrome;
+})
+)JS";
+  std::string shim(kShim);
+  base::ReplaceSubstringsAfterOffset(&shim, 0, "__EXTENSION_ID__",
+                                     extension_id);
+  return shim;
+}
+
+// Resolves `resolver` (in `context`) with a v8 string built from `value`. Bound
+// into the ExtensionApi.StorageGet reply; runs on the renderer main thread.
+void ResolveWithString(v8::Isolate* isolate,
+                       v8::Global<v8::Context> context_global,
+                       v8::Global<v8::Promise::Resolver> resolver_global,
+                       const std::string& value) {
+  v8::HandleScope handle_scope(isolate);
+  v8::Local<v8::Context> context = context_global.Get(isolate);
+  v8::Context::Scope context_scope(context);
+  // Blink runs V8 with the scoped-microtask policy, so resolving a promise
+  // (which enqueues microtasks) must happen inside a MicrotasksScope.
+  v8::MicrotasksScope microtasks_scope(context,
+                                       v8::MicrotasksScope::kRunMicrotasks);
+  v8::Local<v8::Promise::Resolver> resolver = resolver_global.Get(isolate);
+  v8::Local<v8::String> v8str;
+  if (!v8::String::NewFromUtf8(isolate, value.c_str(), v8::NewStringType::kNormal,
+                               value.size())
+           .ToLocal(&v8str)) {
+    return;
+  }
+  // Resolution failure (e.g. detached context) is non-fatal; swallow it.
+  if (resolver->Resolve(context, v8str).IsNothing()) {
+    return;
+  }
+}
+
+// Resolves `resolver` with undefined. Bound into the set/remove/clear replies.
+void ResolveVoid(v8::Isolate* isolate,
+                 v8::Global<v8::Context> context_global,
+                 v8::Global<v8::Promise::Resolver> resolver_global) {
+  v8::HandleScope handle_scope(isolate);
+  v8::Local<v8::Context> context = context_global.Get(isolate);
+  v8::Context::Scope context_scope(context);
+  // See ResolveWithString: promise resolution needs an open MicrotasksScope.
+  v8::MicrotasksScope microtasks_scope(context,
+                                       v8::MicrotasksScope::kRunMicrotasks);
+  v8::Local<v8::Promise::Resolver> resolver = resolver_global.Get(isolate);
+  if (resolver->Resolve(context, v8::Undefined(isolate)).IsNothing()) {
+    return;
+  }
+}
+
+}  // namespace
+
+ShellExtensionContextBindings::ShellExtensionContextBindings(
+    RenderFrame* render_frame,
+    v8::Local<v8::Context> context,
+    const std::string& extension_id)
+    : render_frame_(render_frame),
+      extension_id_(extension_id),
+      isolate_(v8::Isolate::GetCurrent()),
+      context_(v8::Isolate::GetCurrent(), context) {}
+
+ShellExtensionContextBindings::~ShellExtensionContextBindings() = default;
+
+void ShellExtensionContextBindings::EnsureApi() {
+  if (!api_.is_bound()) {
+    render_frame_->GetBrowserInterfaceBroker().GetInterface(
+        api_.BindNewPipeAndPassReceiver());
+  }
+}
+
+void ShellExtensionContextBindings::Install() {
+  v8::HandleScope handle_scope(isolate_);
+  v8::Local<v8::Context> context = context_.Get(isolate_);
+  v8::Context::Scope context_scope(context);
+  v8::TryCatch try_catch(isolate_);
+
+  // Native bridge object passed into the shim function (never leaks to a global).
+  v8::Local<v8::Object> api = v8::Object::New(isolate_);
+  auto install_fn =
+      [&](const char* name,
+          v8::Local<v8::Value> (ShellExtensionContextBindings::*method)(
+              gin::Arguments*)) {
+        // base::Unretained is safe: these functions live in the v8 context this
+        // object backs, which is released (and this object destroyed) before the
+        // RenderFrame, so they are never invoked after `this` is gone. (A WeakPtr
+        // can't be used — base forbids binding one to a non-void-returning
+        // method.)
+        v8::Local<v8::Function> fn;
+        if (!gin::CreateFunctionTemplate(
+                 isolate_, base::BindRepeating(method, base::Unretained(this)))
+                 ->GetFunction(context)
+                 .ToLocal(&fn)) {
+          return;
+        }
+        if (api->Set(context, gin::StringToSymbol(isolate_, name), fn)
+                .IsNothing()) {
+          return;
+        }
+      };
+  install_fn("storageGet", &ShellExtensionContextBindings::StorageGet);
+  install_fn("storageSet", &ShellExtensionContextBindings::StorageSet);
+  install_fn("storageRemove", &ShellExtensionContextBindings::StorageRemove);
+  install_fn("storageClear", &ShellExtensionContextBindings::StorageClear);
+  install_fn("sendMessage", &ShellExtensionContextBindings::SendMessage);
+
+  // setMessageDispatcher returns void, so bind it directly.
+  {
+    v8::Local<v8::Function> fn;
+    if (gin::CreateFunctionTemplate(
+            isolate_,
+            base::BindRepeating(
+                &ShellExtensionContextBindings::SetMessageDispatcher,
+                base::Unretained(this)))
+            ->GetFunction(context)
+            .ToLocal(&fn)) {
+      if (api->Set(context,
+                   gin::StringToSymbol(isolate_, "setMessageDispatcher"), fn)
+              .IsNothing()) {
+        return;
+      }
+    }
+  }
+
+  std::string shim = BuildChromeShim(extension_id_);
+  v8::Local<v8::String> source;
+  if (!v8::String::NewFromUtf8(isolate_, shim.c_str(),
+                               v8::NewStringType::kNormal, shim.size())
+           .ToLocal(&source)) {
+    return;
+  }
+  v8::Local<v8::Script> script;
+  if (!v8::Script::Compile(context, source).ToLocal(&script)) {
+    return;
+  }
+  v8::Local<v8::Value> fn_value;
+  // Errors in the shim are non-fatal; just swallow them.
+  if (!script->Run(context).ToLocal(&fn_value) || !fn_value->IsFunction()) {
+    return;
+  }
+  v8::Local<v8::Function> shim_fn = fn_value.As<v8::Function>();
+  v8::Local<v8::Value> argv[] = {api};
+  v8::Local<v8::Value> ignored;
+  if (!shim_fn->Call(context, context->Global(), 1, argv).ToLocal(&ignored)) {
+    return;
+  }
+
+  // Register this context for message routing now that its dispatcher is set.
+  EnsureApi();
+  api_->RegisterContext(extension_id_,
+                        client_receiver_.BindNewPipeAndPassRemote());
+}
+
+void ShellExtensionContextBindings::OnMessage(const std::string& message_json,
+                                              const std::string& sender_json) {
+  v8::HandleScope handle_scope(isolate_);
+  v8::Local<v8::Context> context = context_.Get(isolate_);
+  v8::Context::Scope context_scope(context);
+  v8::MicrotasksScope microtasks_scope(context,
+                                       v8::MicrotasksScope::kRunMicrotasks);
+  if (message_dispatcher_.IsEmpty()) {
+    return;
+  }
+  v8::Local<v8::Function> dispatcher = message_dispatcher_.Get(isolate_);
+  v8::Local<v8::String> msg;
+  v8::Local<v8::String> sender;
+  if (!v8::String::NewFromUtf8(isolate_, message_json.c_str(),
+                               v8::NewStringType::kNormal, message_json.size())
+           .ToLocal(&msg) ||
+      !v8::String::NewFromUtf8(isolate_, sender_json.c_str(),
+                               v8::NewStringType::kNormal, sender_json.size())
+           .ToLocal(&sender)) {
+    return;
+  }
+  v8::Local<v8::Value> argv[] = {msg, sender};
+  v8::Local<v8::Value> ignored;
+  if (!dispatcher->Call(context, context->Global(), 2, argv).ToLocal(&ignored)) {
+    return;
+  }
+}
+
+void ShellExtensionContextBindings::SetMessageDispatcher(gin::Arguments* args) {
+  v8::Local<v8::Value> value;
+  if (args->GetNext(&value) && value->IsFunction()) {
+    message_dispatcher_.Reset(isolate_, value.As<v8::Function>());
+  }
+}
+
+v8::Local<v8::Value> ShellExtensionContextBindings::SendMessage(
+    gin::Arguments* args) {
+  std::string message_json;
+  args->GetNext(&message_json);
+  EnsureApi();
+  api_->SendMessage(message_json);
+  return v8::Undefined(isolate_);
+}
+
+v8::Local<v8::Value> ShellExtensionContextBindings::StorageGet(
+    gin::Arguments* args) {
+  std::string extension_id;
+  args->GetNext(&extension_id);
+
+  v8::Local<v8::Context> context = isolate_->GetCurrentContext();
+  v8::Local<v8::Promise::Resolver> resolver;
+  if (!v8::Promise::Resolver::New(context).ToLocal(&resolver)) {
+    return v8::Undefined(isolate_);
+  }
+  v8::Local<v8::Promise> promise = resolver->GetPromise();
+
+  EnsureApi();
+  api_->StorageGet(
+      extension_id,
+      base::BindOnce(&ResolveWithString, isolate_.get(),
+                     v8::Global<v8::Context>(isolate_, context),
+                     v8::Global<v8::Promise::Resolver>(isolate_, resolver)));
+  return promise;
+}
+
+v8::Local<v8::Value> ShellExtensionContextBindings::StorageSet(
+    gin::Arguments* args) {
+  std::string extension_id;
+  std::string items_json;
+  args->GetNext(&extension_id);
+  args->GetNext(&items_json);
+
+  v8::Local<v8::Context> context = isolate_->GetCurrentContext();
+  v8::Local<v8::Promise::Resolver> resolver;
+  if (!v8::Promise::Resolver::New(context).ToLocal(&resolver)) {
+    return v8::Undefined(isolate_);
+  }
+  v8::Local<v8::Promise> promise = resolver->GetPromise();
