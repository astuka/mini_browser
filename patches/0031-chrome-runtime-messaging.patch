+#ifndef CONTENT_SHELL_RENDERER_SHELL_EXTENSION_CONTEXT_BINDINGS_H_
+#define CONTENT_SHELL_RENDERER_SHELL_EXTENSION_CONTEXT_BINDINGS_H_
+
+#include <string>
+
+#include "base/memory/raw_ptr.h"
+#include "content/shell/common/shell_extension_api.mojom.h"
+#include "mojo/public/cpp/bindings/receiver.h"
+#include "mojo/public/cpp/bindings/remote.h"
+#include "v8/include/v8-forward.h"
+#include "v8/include/v8-persistent-handle.h"
+
+namespace gin {
+class Arguments;
+}  // namespace gin
+
+namespace content {
+
+class RenderFrame;
+
+// The renderer half of the browser-backed `chrome.*` runtime, instantiated once
+// per extension context — an extension page's main world or a content-script
+// isolated world (Wield epic). It owns that context's ExtensionApi pipe to the
+// browser, installs the native `chrome.storage` + `chrome.runtime` messaging
+// bridge into the v8 context (via gin), and receives pushed runtime messages on
+// its ExtensionApiClient receiver to dispatch into the context's onMessage
+// listeners.
+//
+// Lifetime is tied to the v8 context: the owning ShellRenderFrameObserver
+// creates one in DidCreateScriptContext and destroys it in
+// WillReleaseScriptContext, which drops both pipes and removes the context from
+// the browser's routing registry.
+class ShellExtensionContextBindings : public mojom::ExtensionApiClient {
+ public:
+  ShellExtensionContextBindings(RenderFrame* render_frame,
+                                v8::Local<v8::Context> context,
+                                const std::string& extension_id);
+  ~ShellExtensionContextBindings() override;
+
+  ShellExtensionContextBindings(const ShellExtensionContextBindings&) = delete;
+  ShellExtensionContextBindings& operator=(
+      const ShellExtensionContextBindings&) = delete;
+
+  // Builds the native bridge object, runs the `chrome.*` shim with it, and
+  // registers this context with the browser for message routing.
+  void Install();
+
+  // mojom::ExtensionApiClient:
+  void OnMessage(const std::string& message_json,
+                 const std::string& sender_json) override;
+
+ private:
+  // gin-bound native functions exposed to the shim. The storage ones return a JS
+  // Promise; sendMessage returns undefined; setMessageDispatcher stores the JS
+  // callback the shim uses to deliver incoming messages to onMessage listeners.
+  v8::Local<v8::Value> StorageGet(gin::Arguments* args);
+  v8::Local<v8::Value> StorageSet(gin::Arguments* args);
+  v8::Local<v8::Value> StorageRemove(gin::Arguments* args);
+  v8::Local<v8::Value> StorageClear(gin::Arguments* args);
+  v8::Local<v8::Value> SendMessage(gin::Arguments* args);
+  void SetMessageDispatcher(gin::Arguments* args);
+
+  // Lazily binds the ExtensionApi pipe to the browser.
+  void EnsureApi();
+
+  raw_ptr<RenderFrame> render_frame_;  // Outlives this (via observer's map).
+  std::string extension_id_;
+  raw_ptr<v8::Isolate> isolate_;
+  v8::Global<v8::Context> context_;
+  // The shim's JS function that fans an incoming message out to onMessage
+  // listeners; set via SetMessageDispatcher.
+  v8::Global<v8::Function> message_dispatcher_;
+
+  mojo::Remote<mojom::ExtensionApi> api_;
+  mojo::Receiver<mojom::ExtensionApiClient> client_receiver_{this};
+};
+
+}  // namespace content
+
+#endif  // CONTENT_SHELL_RENDERER_SHELL_EXTENSION_CONTEXT_BINDINGS_H_
