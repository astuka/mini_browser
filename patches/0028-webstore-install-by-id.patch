 namespace {
 // The single shared controller for the whole process. Strong under ARC.
 TabbedShellController* g_tab_controller = nil;
+
+// Extracts a 32-char [a-p] extension id from either a bare id or a Chrome Web
+// Store URL (".../detail/<slug>/<id>"). Returns "" if no valid id is found.
+std::string ExtractWebStoreId(std::string input) {
+  // Trim whitespace.
+  while (!input.empty() && std::isspace(static_cast<unsigned char>(input.back())))
+    input.pop_back();
+  while (!input.empty() && std::isspace(static_cast<unsigned char>(input.front())))
+    input.erase(0, 1);
+  // Drop any query/fragment.
+  input = input.substr(0, input.find_first_of("?#"));
+  // Take the last path segment if it looks like a URL/path.
+  size_t slash = input.find_last_of('/');
+  if (slash != std::string::npos)
+    input = input.substr(slash + 1);
+  // Validate: exactly 32 chars, all in a–p.
+  if (input.size() != 32)
+    return std::string();
+  for (char c : input) {
+    if (c < 'a' || c > 'p')
+      return std::string();
+  }
+  return input;
+}
+
+// SimpleURLLoader completion (UI thread): hands the downloaded CRX to the
+// controller, or signals failure with an empty path.
+void OnWebStoreCrxDownloaded(base::FilePath path) {
+  [g_tab_controller finishWebStoreInstallWithCrxPath:
+                        path.empty()
+                            ? nil
+                            : base::SysUTF8ToNSString(path.value())];
+}
 }  // namespace
 
