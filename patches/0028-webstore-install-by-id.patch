+// Installs an extension by Chrome Web Store id (E9): fetches the Google-vetted
+// CRX from the public update endpoint, then runs it through the E8 verify +
+// unpack + register pipeline. We only use the legitimate public update flow.
+- (void)installFromWebStore:(id)sender {
+  std::string extension_id =
+      ExtractWebStoreId(base::SysNSStringToUTF8(_webStoreField.stringValue));
+  if (extension_id.empty()) {
+    [self showExtensionError:@"Enter a 32-character extension id, or a Chrome "
+                             @"Web Store URL."];
+    return;
+  }
+
+  content::Shell* active = [self activeShell];
+  content::BrowserContext* browser_context =
+      active ? active->web_contents()->GetBrowserContext() : nullptr;
+  if (!browser_context)
+    return;
+
+  // The public CRX update endpoint; response=redirect sends us to the CDN copy.
+  GURL url("https://clients2.google.com/service/update2/crx?response=redirect&"
+           "acceptformat=crx3&prodversion=131.0.0.0&x=id%3D" +
+           extension_id + "%26installsource%3Dondemand%26uc");
+
+  auto request = std::make_unique<network::ResourceRequest>();
+  request->url = url;
+  _webStoreLoader = network::SimpleURLLoader::Create(
+      std::move(request), TRAFFIC_ANNOTATION_FOR_TESTS);
+  scoped_refptr<network::SharedURLLoaderFactory> factory =
+      browser_context->GetDefaultStoragePartition()
+          ->GetURLLoaderFactoryForBrowserProcess();
+  _webStoreField.stringValue = @"Downloading…";
+  _webStoreLoader->DownloadToTempFile(
+      factory.get(), base::BindOnce(&OnWebStoreCrxDownloaded));
+}
+
+- (void)finishWebStoreInstallWithCrxPath:(NSString*)path {
+  _webStoreLoader.reset();
+  _webStoreField.stringValue = @"";
+  if (!path.length) {
+    [self showExtensionError:@"Couldn't download that extension from the Web "
+                             @"Store. Check the id and your connection."];
+    return;
+  }
+  [self installCrxFromPath:path];
+  base::ScopedAllowBlockingForTesting allow_blocking;
+  base::DeleteFile(base::FilePath(base::SysNSStringToUTF8(path)));
+}
