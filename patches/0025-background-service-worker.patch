+// Generates the background-page wrapper HTML for an extension by reading its
+// manifest's `background.service_worker` (+ optional `background.type`). Runs on
+// a MayBlock thread pool task.
+FileResult BuildBackgroundPage(base::FilePath root) {
+  FileResult result;
+  std::string manifest_text;
+  if (!base::ReadFileToString(root.Append("manifest.json"), &manifest_text)) {
+    result.error = net::ERR_FILE_NOT_FOUND;
+    return result;
+  }
+  std::optional<base::Value> parsed = base::JSONReader::Read(
+      manifest_text, base::JSON_PARSE_CHROMIUM_EXTENSIONS);
+  if (!parsed || !parsed->is_dict()) {
+    result.error = net::ERR_FILE_NOT_FOUND;
+    return result;
+  }
+  const base::DictValue* background = parsed->GetDict().FindDict("background");
+  const std::string* script =
+      background ? background->FindString("service_worker") : nullptr;
+  if (!script || script->empty()) {
+    result.error = net::ERR_FILE_NOT_FOUND;
+    return result;
+  }
+  // The script path comes from the extension's own manifest, but guard against
+  // characters that would break out of the HTML attribute just in case.
+  if (script->find_first_of("\"'<>") != std::string::npos) {
+    result.error = net::ERR_INVALID_RESPONSE;
+    return result;
+  }
+  const std::string* type =
+      background ? background->FindString("type") : nullptr;
+  bool is_module = type && *type == "module";
+
+  result.data =
+      "<!doctype html><meta charset=\"utf-8\"><title>background</title>\n";
+  result.data += is_module ? "<script type=\"module\" src=\"" : "<script src=\"";
+  result.data += *script;
+  result.data += "\"></script>\n";
+  result.mime_type = "text/html";
+  result.error = net::OK;
+  return result;
+}
