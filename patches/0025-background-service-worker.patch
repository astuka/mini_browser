+// Hosts a persistent background page (a hidden WebContents) for each enabled
+// extension that declares an MV3 background.service_worker, and tears down those
+// no longer wanted. Our reduced "background service worker" model (E6): the
+// script runs in a long-lived extension-origin document, which already gets the
+// chrome.* shim (E5). Idempotent — safe to call repeatedly.
+- (void)rebuildBackgroundPages {
+  content::Shell* active = [self activeShell];
+  content::BrowserContext* browser_context =
+      active ? active->web_contents()->GetBrowserContext() : nullptr;
+  if (!browser_context)
+    return;
+
+  // Collect enabled extensions that declare a background script.
+  std::set<std::string> wanted;
+  base::DictValue exts =
+      content::ShellContentBrowserClient::Get()->GetExtensions();
+  for (auto&& [id_key, value] : exts) {
+    if (!value.is_dict())
+      continue;
+    if (!value.GetDict().FindBool("enabled").value_or(true))
+      continue;
+    std::optional<base::Value> manifest =
+        [self readManifestForExtensionId:base::SysUTF8ToNSString(id_key)];
+    if (!manifest || !manifest->is_dict())
+      continue;
+    const base::DictValue* background =
+        manifest->GetDict().FindDict("background");
+    const std::string* sw =
+        background ? background->FindString("service_worker") : nullptr;
+    if (sw && !sw->empty())
+      wanted.insert(id_key);
+  }
+
+  // Tear down background pages that are no longer wanted.
+  for (auto it = _backgroundPages.begin(); it != _backgroundPages.end();) {
+    if (wanted.find(it->first) == wanted.end())
+      it = _backgroundPages.erase(it);
+    else
+      ++it;
+  }
+
+  // Start background pages for newly-wanted extensions.
+  for (const std::string& id : wanted) {
+    if (_backgroundPages.count(id))
+      continue;
+    GURL url("chrome-extension://" + id + "/__shell_background.html");
+    content::WebContents::CreateParams params(browser_context);
+    std::unique_ptr<content::WebContents> contents =
+        content::WebContents::Create(params);
+    contents->GetController().LoadURL(url, content::Referrer(),
+                                      ui::PAGE_TRANSITION_AUTO_TOPLEVEL,
+                                      std::string());
+    _backgroundPages[id] = std::move(contents);
+  }
+}
